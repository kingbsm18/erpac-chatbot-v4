getLogTime = ->
  new Date().toString()

class WebConsole extends Proxy
  constructor: (option) ->
    super option

    @odpsProxy = new OdpsProxy @options

    @timeout = 100000

    @odps_objects =
      'tables' : 1
      'resources' : 1
      'registration' : 1
      'jobs' : 1
      'instances' : 1
      'authorization' : 1
      'users' : 1
      'roles' : 1

    # @proxy2_url_map =
    #   "ots-intranet.aliyuncs.com" : 1
    #   "service.ots.aliyun-inc.com" : 1
    #   "service.ots.aliyun.com" : 1
    #   "login-test.alibaba-inc.com" : 1
    #   "login.alibaba-inc.com" : 1

  middleware : ->
    (req, resp, next) =>
      @proxy req, resp

  done : (body, res, statusCode) ->
    if typeof(statusCode) is 'undefined'
      statusCode = 200
    res.statusCode = statusCode
    res.end body

  error : (err, res) ->
    err = JSON.stringify err if typeof(err) is 'object'
    res.writeHead 500
    res.end err

  sayNotFound : (req, res) ->
    res.writeHead 404
    res.end 'Cannot ' + req.method + ' ' + req.url

  checkOdpsPath : (url_path) ->
    return false if url_path.indexOf('../') isnt -1 or url_path.indexOf('/projects') is -1
    subpath = url_path.substring url_path.indexOf('/projects') + 1

    arr = subpath.split '/'

    return false if arr.length < 1 or arr[0] isnt 'projects'

    return false if arr.length > 2 and !@odps_objects[arr[2]]
    return true

  parseUrl : (req, res, cb) ->
    url = queryString.unescape req.url
    urlObject = parse url, true
    query = urlObject.query
    method = req.method.toLowerCase()
    if method is 'post' or method is 'put'
      chunks = []
      req.on 'data', (chunk) =>
        chunks.push chunk

      req.on 'error', (err) =>
        @error err, res

      req.on 'end', () =>
        postData = Buffer.concat(chunks).toString()
        postData = queryString.unescape postData
        cb query, postData
    else
      cb query

  proxy : (req, res) ->
    if req.headers['content-type'] is 'application/xml; charset=UTF-8'
      req.headers['content-type'] = 'application/xml'
    @parseUrl req, res, (param, body) =>
      return @sayNotFound req, res unless param.url

      return @sayNotFound req, res unless @checkOdpsPath param.url or ''

      @getAppAuth req, param, (err, owner)=>
        return @error err, res if err
        opt =
          autoParse : false
          AuthInfo :
            id : owner.odpsAccessId
            key : owner.odpsAccessKey
          method : req.method
          url : param.url
          head : req.headers
          body : body || ''
        @odpsProxy.req opt, (err, response, body, statusCode) =>
          return @error err, res if err
          @done body, res, statusCode

  getProdOrDevAppInfo : (appName, req, cb) ->
    requestParam =
      "odpsProjectName": appName

    opt = 
      url : 'application/ApplicationAPI/getApplications'
      param : requestParam

    @request opt, req, (err, resp, body) =>
      return cb err if err
      result = JSON.parse body
      return cb body if result.returnCode isnt '0'
      if result.returnValue && result.returnValue.length > 0
        cb null, result.returnValue[0]
      else
        cb null, null

  getAppAuth : (req, param, cb) ->
    userId = req.session.user.id
    appName = param.appName
    unless appName
      cb '没有应用信息'
      return

    self = @
    pipe = ep()

    pipe.add ->
      self.getProdOrDevAppInfo appName, req, (err, appInfo)=>
        if err
          cb err
          @__stop()
          return
        @appInfo = appInfo
        @()

    pipe.add ->
      return @() if @appInfo
      devIndex = appName.lastIndexOf self.options.devAppFlag
      devAppFlagIndex = appName.length - self.options.devAppFlag.length
      if devIndex isnt devAppFlagIndex
        cb "应用#{appName}不存在"
        @__stop()
        return
      devAppName = appName.substr 0, devAppFlagIndex
      self.getProdOrDevAppInfo devAppName, req, (err, appInfo) =>
        if err
          cb err
          @__stop()
          return
        unless appInfo
          cb "应用#{appName}不存在"
          @__stop()
          return
        @appInfo = appInfo
        @()

    pipe.add ->
      self.getUserOdpsInfos userId : @appInfo.owner, req, (err, resp, body) =>
        if err
          cb err
          @__stop()
        else
          result = body.returnValue
          if result and result.odpsAccessId and result.odpsDisplayName and result.odpsAccessKey
            @ownerInfo = result
            @()
          else
            cb "应用#{appName}的负责人没有云账号或者云账号信息不全"
            @__stop()

    pipe.add ->
      self.authConsole req, {appId :@appInfo.id}, (err, body) =>
        if err
          cb err
          @__stop()
        else if body is true
          @()
        else
          cb "没有操作权限"
          @__stop()

    pipe.add ->
      cb null, @ownerInfo
      @()

    pipe.run()

