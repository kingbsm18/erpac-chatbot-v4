  middleware : () ->
    (req, resp, next) =>
      @proxy req, resp

  proxy : (req, resp) ->
    url = queryString.unescape req.url
    urlObject = parse url, true
    urls = urlObject.pathname.split '/'
    urls.shift()
    resource = urls.shift()
    method = urls.shift()
    if !resource or !method
      @error "request url must has resource and method", resp
    else if @proxys[resource] and @proxys[resource][method]
      resourceHanlder = @proxys[resource]
      @parseUrl req, (err, param) =>
        return @error err, resp if err
        try
          param = os param, @parseProxyParam urls
          resourceHanlder[method].call resourceHanlder, req, resp, param, @
        catch err
          @error err, resp
    else
      urls.shift()
      @parseUrl req, (err, param) =>
        return @error err, resp if err
        param = @parseRestParam urls
        @sendRest req, resp, param
    @

  parseUrl : (req, cb) ->
    url = queryString.unescape req.url
    urlObject = parse url, true
    query = urlObject.query
    method = req.method.toLowerCase()
    if method is 'post' or method is 'put'
      chunks = []
      req.on 'data', (chunk) ->
        chunks.push chunk

      req.on 'error', (err) ->
        cb err

      req.on 'end', () ->
        postData = Buffer.concat(chunks).toString()
        postData = queryString.unescape postData
        postData = postData.substr 1
        postData = JSON.parse postData
        query = os postData, query
        cb null, query
    else
      cb null, query

  parseProxyParam : (urls) ->
    param = {}
    if urls and urls.length > 0
      param = urls[0]
      pageStart = urls[1]
      pageSize = urls[2]
      param = JSON.parse decodeURIComponent param
      param.pageStart = pageStart * 1 if typeof(pageStart) isnt 'undefined'
      param.pageSize = pageSize * 1 if typeof(pageSize) isnt 'undefined'
    param

  parseRestParam : (urls) ->
    param = ''
    if urls and urls.length > 0
      param = urls[0]
      pageStart = urls[1]
      pageSize = urls[2]
      param = decodeURIComponent param
      try
        param = JSON.parse param
        param.pageStart = pageStart * 1 if typeof(pageStart) isnt 'undefined'
        param.pageSize = pageSize * 1 if typeof(pageSize) isnt 'undefined'
        param = JSON.stringify param
      catch e
        param = param
    param

  sendRest : (req, response, param) ->
    url = queryString.unescape req.url
    urlObject = parse url, true
    urls = urlObject.pathname.split '/'
    defaultParam = getDefaultParam req

    process.honeycomb.rest.getUrl '', urls[1], urls[2], urls[3], [JSON.stringify(defaultParam), param], {}, (err, uri) =>
      if err
        @error err, response
      else
        @log.info 'param' : uri
        requestOpt = 
          method : 'get'
          url : uri
        @_request requestOpt, (err, resp, body) =>
          @done body, response

  error : (error, resp) ->
    title = 'error'
    err =
      returnCode : '100001'
    if typeof(error) is 'object'
      title = error.title if error.title
      if error.code
        err.returnMessage = error.code + ': ' + error.message
      else if typeof error.returnCode isnt 'undefined'
        err = error
      else
        err.returnMessage = error.message
    else
      err.returnMessage = error
    @log.error 'error' : title + ': ' + JSON.stringify err
    resp.statusCode = 200
    resp.end JSON.stringify err

  done : (body, resp) ->
    resp.statusCode = 200
    resp.end body

class Project extends Proxy
  constructor : (option) ->
    super option

    @odpsProject = OdpsProject @options
    @odpsUser = OdpsUser @options

  clusterConfig : (req, response, param, proxy) ->
    @odpsProject.getClusterConfig {
        'authInfo' : @authInfo
      }, (err, resp, body)=>
        proxy.done JSON.stringify(body), response

  # 新建应用
  create : (req, response, param, proxy) ->
    self = @
    pipe = ep()
    # 针对在云端页面新建用户操作，判断只有白名单中的用户才能新建用户
    pipe.add ->
      if param.isCloudWeb
        if self.hasCreateAuth req.session.user.id
          @()
        else
          err =
            returnCode : '999999999'
            returnMessage : "您没有权限新建应用"
          proxy.error err, response
          @__stop()
      else
        @()

    pipe.add () ->
      self.getUser param, req, (err, user) =>
        if err
          proxy.error err, response
          @__stop()
        else
          @user = user
          @()

    pipe.add () ->
      @ownerAuthInfo =
        'accessId' : @user.odpsAccessId
        'accessKey' : @user.odpsAccessKey
      @projects = []
      @()

    # 检测odps项目是否存在
    pipe.add ->
      requestParam =
        "odpsProjectName": param.odpsProjectName

      opt = 
        url : 'application/ApplicationAPI/getApplications'
        param : requestParam

      self.request opt, req, (err, resp, body) =>
        if err
          err.title = 'check-project-error'
          proxy.error err, response
          @__stop()
        else
          result = JSON.parse body
          if result.returnCode isnt '0'
            proxy.error result, response
            @__stop()
          else if result.returnValue && result.returnValue.length > 0
            err =
              returnCode : '999999999'
              returnMessage : "#{param.odpsProjectName}已经存在"
            proxy.error err, response
            @__stop()
          else
            @()
    # 新建项目
    pipe.add [
      () -> 
        odpsInfo =
          'priority' : '3'
          'clusters' : param.devClusters
          'bu' : param.odpsBu
          'storageQuota' : param.devStorageQuota
          'fileNumber' : param.devFileNumber
          'defaultCluster' : param.devClusters[0]
        self.createProjects req, response, param, odpsInfo, proxy, @, true, (err, body) =>
          if err
            proxy.error err, response
            @__stop()
          else
            @projects.push body
            @()
      , 
      () ->
        odpsInfo =
          'priority' : '1'
          'clusters' : param.prdClusters
          'bu' : param.odpsBu
          'storageQuota' : param.prdStorageQuota
          'fileNumber' : param.prdFileNumber
          'defaultCluster' : param.prdClusters[0]
        self.createProjects req, response, param, odpsInfo, proxy, @, false, (err, body) =>
          if err
            proxy.error err, response
            @__stop()
          else
            @projects.push body
            @()
    ]

    # 添加生产项目的执行账号
    pipe.add () ->
      self.aliyun.randUser @user.id, (err, userInfo) =>
        if err
          proxy.error err, response
          @__stop()
        @accessAuth = userInfo
        @()

    # 将生产项目执行账号添加到生产项目里面
    pipe.add () ->
      self.odpsUser.add {
        'name' : param.odpsProjectName,
        'userName' : @accessAuth.odpsDisplayName,
        'authInfo' : @ownerAuthInfo
        }, @

    pipe.add (err, resp, body) ->
      if err
        proxy.error err, response
        @__stop()
      else
        @()

    # 给执行账号添加admin角色
    pipe.add () ->
      self.odpsUser.grant {
        'name' : param.odpsProjectName,
        'roles' : 'admin',
        'userName' : @accessAuth.odpsDisplayName,
        'authInfo' : @ownerAuthInfo
      }, @

    pipe.add (err, resp, body) ->
      if err
        proxy.error err, response
        @__stop()
      else
        @()

    # 在在云端新建应用
    pipe.add () ->
      requestParam =
        "odpsProjectName": param.odpsProjectName
        "odpsDisplayName": @accessAuth.odpsDisplayName
        "name": param.appName
        "description": param.description
        "owner": @user.id
        "creator": req.session.user.id
        "type": 10
        "odpsAccessId": @accessAuth.odpsAccessId
        "odpsAccessKey": @accessAuth.odpsAccessKey

      opt = 
        url : 'application/ApplicationAPI/createApp'
        param : requestParam

      self.request opt, req, (err, resp, body) =>
        if err
          err.title = 'create-project-error'
          proxy.error err, response
          @__stop()
        else
          proxy.done body, response
          @()

    pipe.run()

  createProjects : (req, response, param, odpsInfo, proxy, options, isDev, cb) ->
    self = @
    pipe = ep()
    prefix = if isDev then self.options.devAppFlag else ''

    # 建立odps的生产项目
    pipe.add () ->
      self.createOdpsProject {
        'name' : param.odpsProjectName,
        'authInfo' : self.authInfo,
        'odpsInfo' : odpsInfo,
        'prefix' : prefix,
        'roles' : if isDev then devRoles else prodRoles,
        'user' : options.user
      }, options.user, (err, body) =>
        if err
          proxy.error err, response
          @__stop()
        else
          @project = body
          @()

    pipe.add () ->
      cb null, @project
      @()

    pipe.run()

  createOdpsProject : (param, user, cb) ->
    self = @
    createRoleFns = []
    param.prefix = param.prefix || ''
    appName = param.name + param.prefix

    pipe = ep()
    pipe.add () ->
      @ownerAuthInfo =
        'accessId' : user.odpsAccessId
        'accessKey' : user.odpsAccessKey
        'prefix' : param.prefix
      @()
    # 创建应用
    pipe.add () ->
      self.odpsProject.create {
        'name' : appName,
        'owner' : param.user.id,
        'email' : param.user.odpsDisplayName,
        'odpsInfo' : param.odpsInfo,
        'authInfo' : param.authInfo
      }, @
    # 处理创建应用后的返回信息
    pipe.add (err, resp, body) ->
      if err
        cb err
        @__stop()
      else
        @project = body
        @()
    # 将角色加入应用里面
    roleNames = []
    for role in param.roles
      roleNames.push role.name
      pipe.add ->
        self.createRole appName, @ownerAuthInfo, role, (err) =>
          if err
            cb err
            @__stop()
          else
            @()

    # 注册事件
    pipe.add () ->
      self.odpsProject.registEvents {
        'name' : appName,
        'eventName' : 'meta_data_event',
        'eventComment' : 'metadata callback',
        'eventType' : 'Table',
        'propertis' : [{
          'name' : 'source',
          'value' : '*'
          }],
        'callBackUrl' : self.options.metaDataCallBackUrl,
        'authInfo' : @ownerAuthInfo
      }, @

    pipe.add (err, resp, body) ->
      if err
        cb err
        @__stop()
      else
        @()

    pipe.add () ->
      cb null, @project
      @()

    pipe.run()
  # 添加角色并且赋权
  createRole : (appName, authInfo, role, cb) ->
    _roleName = role.name
    _policyPath = if authInfo.prefix then 'dev.default.policy.yaml' else 'prd.default.policy.yaml'
    self = @
    pipeRole = ep()
    # 创建角色
    pipeRole.add () ->
      self.odpsProject.createRole {
        'name' : appName,
        'role' : _roleName,
        'authInfo' : authInfo
      }, @

    pipeRole.add (err, resp, body) ->
      if err
        cb err
        @__stop()
      else
        @()
    # 给角色赋权
    pipeRole.add () ->
      # 权限绑给role 负责人就是admin
      policyConf = yaml.load path.join self.options.policyDir, _policyPath

      self.odpsUser.grantRole {
        'name' : appName,
        'roleName' : _roleName,
        'authInfo' : authInfo
        'body' : policyConf
      }, (err, resp, body) =>
        if err
          cb err
          @__stop()
        else
          @()

    pipeRole.add () ->
      cb()
      @()

    pipeRole.run()

  # 更新应用
  update : (req, response, param, proxy) ->
    self = @

    pipe = ep()
    pipe.add () ->
      self.getUser param, req, (err, user) =>
        if err
          proxy.error err, response
          @__stop()
        else
          @user = user
          @()

    # 获取原来的应用信息
    pipe.add () ->
      opt = 
        url : 'application/ApplicationAPI/getApplicationById'
        param : param.id

      self.request opt, req, (err, resp, body) =>
        if err
          err.title = 'get-project-error'
          proxy.error err, response
          @__stop()
        else
          result = JSON.parse body
          if (result.returnCode + '') isnt '0'
            proxy.error err, response
            @__stop()
          else
            @app = result.returnValue
            @()

    # 如果变更了owner信息，则更新odps开发项目的owner信息
    pipe.add () ->
      if @app.owner isnt @user.id
        self.updateOdpsAppOwner req, {
          'odpsProjectName' : @app.odpsProjectName,
          'oldOwner' : @app.owner,
          'prefix' : self.options.devAppFlag,
          'roles' : devRoles
          }, @user, (err) =>
            if err
              proxy.error err, response
              @__stop()
            else
              @()
      else
        @()

    # # 如果变更了owner信息，则更新odps生产项目的owner信息
    pipe.add () ->
      if @app.owner isnt @user.id
        self.updateOdpsAppOwner req, {
          'odpsProjectName' : @app.odpsProjectName,
          'oldOwner' : @app.owner,
          'prefix' : '',
          'roles' : prodRoles
          }, @user, (err) =>
            if err
              proxy.error err, response
              @__stop()
            else
              @()
      else
        @()

    # 更新在云端的应用
    pipe.add () ->
      requestParam =
        "id": param.id
        "odpsProjectName": @app.odpsProjectName
        "odpsDisplayName": @app.odpsDisplayName
        "name": @app.name
        "description": param.description
        "owner": @user.id
        "type": @app.type

      opt = 
        url : 'application/ApplicationAPI/updateApp'
        param : requestParam

      self.request opt, req, (err, resp, body) =>
        if err
          err.title = 'update-project-error'
          proxy.error err, response
          @__stop()
        else
          proxy.done body, response
          @()

    pipe.run()

  # 更新odps项目的owner
  updateOdpsAppOwner : (req, param, user, cb) ->
    self = @
    param.prefix = param.prefix || ''
    appName = param.odpsProjectName + param.prefix
    pipe = ep()
    # 获取应用原来的owner信息
    pipe.add () ->
      self.getUser {
        userId : param.oldOwner
        }, req, (err, user) =>
          if err
            cb err
            @__stop()
          else
            @appUser = user
            @()

    # 使用新owner的用户信息赋权
    pipe.add () ->
      @oldOwnerAuthInfo =
        'accessId' : @appUser.odpsAccessId
        'accessKey' : @appUser.odpsAccessKey
      @ownerAuthInfo =
        'accessId' : user.odpsAccessId
        'accessKey' : user.odpsAccessKey
      @()

    # 获取应用的详细信息
    # to do get
    pipe.add () ->
      self.odpsProject.get {
        'name' : appName,
        'authInfo' : self.authInfo
        }, (err, resp, body) =>
          if err
            cb err
            @__stop()
          else
            @appInfo = body
            @()

    # 更新owner
    pipe.add () ->
      @appInfo.owner = user.odpsDisplayName
      @()

    # 更新最新的应用信息
    pipe.add () ->
      self.odpsProject.set {
        'app' : @appInfo,
        'authInfo' : self.authInfo
        }, (err, resp, body) =>
          if err
            cb err
            @__stop()
          else
            @()

    pipe.add () ->
      cb null
      @()

    pipe.run()

class User extends Proxy
  constructor : (option) ->
    super option

    @odpsUser = OdpsUser @options
  # 更新用户的信息，包括添加用户、更新权限等功能
  update : (req, response, param, proxy) ->
    self = @
    roles = param.roles
    roleIds = []
    roleCodes = []
    for role in roles
      roleIds.push role.id
      roleCodes.push role.code

    pipe = ep()
    pipe.add () ->
      self.getUser param, req, (err, user) =>
        if err
          proxy.error err, response
          @__stop()
        else
          @user = user
          @()

    pipe.add () ->
      self.getUser {userId : param.owner}, req, (err, user) =>
        if err
          proxy.error err, response
          @__stop()
        else
          @ownerInfo = user
          @()

    pipe.add () ->
      @ownerAuthInfo =
        'accessId' : @ownerInfo.odpsAccessId
        'accessKey' : @ownerInfo.odpsAccessKey
      @()

    if !@options.notChangeOdpsUser
      # 修改odps的开发环境
      pipe.add () ->
        self.updateOdpsUser {
          'authInfo' : @ownerAuthInfo,
          'odpsProjectName' : param.odpsProjectName,
          'prefix' : self.options.devAppFlag,
          'roles' : devRoles
          }, @user, (err) =>
            if err
              proxy.error err, response
              @__stop()
            else
              @()

      # 修改opps的生产环境
      pipe.add () ->
        self.updateOdpsUser {
          'authInfo' : @ownerAuthInfo,
          'odpsProjectName' : param.odpsProjectName,
          'prefix' : '',
          'roles' : prodRoles
          }, @user, (err) =>
            if err
              proxy.error err, response
              @__stop()
            else
              @()

    pipe.add () ->
      requestParam =
        "userId": @user.id
        "appId": param.appId
        "roles": roleIds

      opt = 
        url : 'application/ApplicationAPI/modifyAppMember'
        param : requestParam
      self.request opt, req, (err, resp, body) =>
        if err
          err.title = 'modify-app-member-error'
          proxy.error err, response
          @__stop()
        else
          proxy.done body, response
          @()

    pipe.run()

  updateOdpsUser : (param, user, cb) ->
    self = @
    param.prefix = param.prefix || ''
    appName = param.odpsProjectName + param.prefix
    pipe = ep()
    # 获取当前项目的所有用户
    pipe.add () ->
      self.odpsUser.list {
        'name' : appName,
        'authInfo' : param.authInfo
        }, @

    pipe.add (err, resp, list) ->
      if err
        cb err
        @__stop()
        return

      _pipe = @
      # 检测用户是否在当前项目中，如果没有则新加
      if !self.inUserList user.odpsDisplayName, list
        userPipe = ep()
        userPipe.add () ->
          self.odpsUser.add {
            'name' : appName,
            'userName' : user.odpsDisplayName,
            'authInfo' : param.authInfo
            }, @

        userPipe.add (err, resp, body) ->
          if err
            cb err
            @__stop()
            _pipe.__stop()
          else
            @()
        roleNames = []
        for role in param.roles
          roleNames.push role.name
        # 给用户添加角色
        userPipe.add () ->
          self.odpsUser.grant {
            'name' : appName,
            'roles' : roleNames.join(','),
            'userName' : user.odpsDisplayName,
            'authInfo' : param.authInfo
          }, @

        userPipe.add (err, resp, body) ->
          if err
            cb err
            @__stop()
            _pipe.__stop()
          else
            @()
            _pipe()

        userPipe.run()
      else
        @()

    pipe.add ->
      cb null

    pipe.run()

  delete : (req, response, param, proxy) ->
    self = @

    pipe = ep()
    pipe.add () ->
      self.getUser param, req, (err, user) =>
        if err
          proxy.error err, response
          @__stop()
        else
          @user = user
          @()

    pipe.add () ->
      self.getUser {userId : param.owner}, req, (err, user) =>
        if err
          proxy.error err, response
          @__stop()
        else
          @ownerInfo = user
          @()

    pipe.add () ->
      @ownerAuthInfo =
        'accessId' : @ownerInfo.odpsAccessId
        'accessKey' : @ownerInfo.odpsAccessKey
      @()

    if !@options.notChangeOdpsUser
      # 删除odps开发项目用户
      pipe.add () ->
        self.deleteOdpsUser {
          'authInfo' : @ownerAuthInfo,
          'appName' : param.odpsProjectName,
          'prefix' : self.options.devAppFlag
          }, @user, (err) =>
            if err
              proxy.error err, response
              @__stop()
            else
              @()

      # 删除odps生产项目用户
      pipe.add () ->
        self.deleteOdpsUser {
          'authInfo' : @ownerAuthInfo,
          'appName' : param.odpsProjectName,
          'prefix' : ''
          }, @user, (err) =>
            if err
              proxy.error err, response
              @__stop()
            else
              @()

    pipe.add () ->
      requestParam =
        "userIds": [@user.id]
        "appId": param.appId

      opt = 
        url : 'application/ApplicationAPI/deleteAppMember'
        param : requestParam
      self.request opt, req, (err, resp, body) =>
        if err
          err.title = 'delete-app-member-error'
          proxy.error err, response
          @__stop()
        else
          proxy.done body, response
          @()

    pipe.run()

  deleteOdpsUser : (param, user, cb) ->
    self = @
    param.prefix = param.prefix || ''
    appName = param.appName + param.prefix
    pipe = ep()
    # 获取当前项目的用户
    pipe.add () ->
      self.odpsUser.removeUser {
        'name' : appName,
        'authInfo' : param.authInfo,
        'userName' : user.odpsDisplayName
        }, @

    pipe.add (err, resp, body) ->
      if err
        cb err
        @__stop()
      else
        cb null
        @()

    pipe.run()

exports = module.exports = (options) ->
  new Apps options
