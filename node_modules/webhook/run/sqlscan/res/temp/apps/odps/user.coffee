os           = require 'options-stream'
util         = require 'util'
Proxy        = require './proxy'

class User
  constructor: (option) ->

    @Proxy = new Proxy option
    # @options = os {
    #   prefix : 'http://10.249.215.1/odps_test'
    # }, option

    @head = 
      'content-type' : 'application/xml'

  add : (data, cb) ->
    url = "/projects/#{data.name}/authorization"
    authInfo = 
      id : data.authInfo.accessId
      key : data.authInfo.accessKey

    body = '<?xml version="1.0" encoding="UTF-8"?>
      <Authorization>
        <Query>
          <![CDATA[
          ADD USER aliyun$' + data.userName + ';
          ]]>
        </Query>
      </Authorization>'

    opt =
      AuthInfo : authInfo
      method : 'POST'
      url : url
      head : @head
      body : body
      prefix : data.prefix

    @Proxy.req opt, (error, response, body) =>
      if error
        cb error, response, body
      else if body.Error
        err = new Error body.Error.Message
        err.code = body.Error.Code
        cb err, response, body
      else
        result = body.Authorization.Result
        if result and result.split(':')[0] is 'OK'
          cb null, response, body
        else
          err = new Error body.Authorization.Result
          err.code = 'ADD-USER-ERROR'
          cb err, response, body

  grant : (data, cb) ->
    url = "/projects/#{data.name}/authorization"
    authInfo = 
      id : data.authInfo.accessId
      key : data.authInfo.accessKey

    body = '<?xml version="1.0" encoding="UTF-8"?>
      <Authorization>
        <Query>
          <![CDATA[
          GRANT ' + data.roles + ' to aliyun$' + data.userName + ';
          ]]>
        </Query>
      </Authorization>'

    opt =
      AuthInfo : authInfo
      method : 'POST'
      url : url
      head : @head
      body : body
      prefix : data.prefix
    @Proxy.req opt, (error, response, body) =>
      if error
        cb error, response, body
      else if body.Error
        err = new Error body.Error.Message
        err.code = body.Error.Code
        cb err, response, body
      else if body.Authorization.Result is 'OK'
        cb null, response, body
      else
        err = new Error body.Authorization.Result
        err.code = 'GRANT-ROLE-TO-USER-ERROR'
        cb err, response, body

  grantRole : (data, cb) ->
    url = "/projects/#{data.name}/roles/#{data.roleName}?policy"
    authInfo = 
      id : data.authInfo.accessId
      key : data.authInfo.accessKey
      
    header = @head
    header['content-type'] = 'application/json'

    body = JSON.stringify data.body

    opt =
      AuthInfo : authInfo
      method : 'PUT'
      url : url
      head : header
      body : body.replace /#{projectname}/g, data.name
      prefix : data.prefix

    @Proxy.req opt, (error, response, body) =>
      if error
        cb error, response, body
      else if response.statusCode is 200
        cb null, response, body
      else
        err = new Error 'GRANT ROLE ERROR'
        err.code = 'GRANT-ROLE-TO-USER-ERROR'
        cb err, response, body

  list : (data, cb) ->
    url = "/projects/#{data.name}/users"
    authInfo = 
      id : data.authInfo.accessId
      key : data.authInfo.accessKey

    body = ""

    opt =
      AuthInfo : authInfo
      method : 'GET'
      url : url
      head : @head
      body : body
      prefix : data.prefix
    @Proxy.req opt, (error, response, body) =>
      if error
        cb error, response, body
      else if body.Error
        err = new Error body.Error.Message
        err.code = body.Error.Code
        cb err, response, body
      else
        users = body.Users.User
        unless users
          users = []
        if !util.isArray(users)
          users = [users]
        cb null, response, users

  removeUser : (data, cb) ->
    url = "/projects/#{data.name}/authorization"
    authInfo = 
      id : data.authInfo.accessId
      key : data.authInfo.accessKey

    body = '<?xml version="1.0" encoding="UTF-8"?>
      <Authorization>
        <Query>
          <![CDATA[
          remove USER aliyun$' + data.userName + ';
          ]]>
        </Query>
      </Authorization>'

    opt =
      AuthInfo : authInfo
      method : 'POST'
      url : url
      head : @head
      body : body
      prefix : data.prefix
    @Proxy.req opt, (error, response, body) =>
      if error
        cb error, response, body
      else if body.Error
        err = new Error body.Error.Message
        err.code = body.Error.Code
        cb err, response, body
      else if body.Authorization.Result is 'OK'
        cb null, response, body
      else
        err = new Error body.Authorization.Result
        err.code = 'DROP-USER-ERROR'
        cb err, response, body

exports = module.exports = (options) ->
  new User options
