.grid-viewport
  height 270px
.authorizerange-list
  margin 20px 20px 10px 20px
.list-field
  display -webkit-flex
.list-left, .list-right
  width 250px
  -webkit-flex 1
  border 1px solid #cacaca 
.list-left, .list-left-title
  margin-right 20px
.list-left-title, .list-right-title
  width 250px
  -webkit-flex 1
  border-top 1px solid #cacaca
  border-left 1px solid #cacaca
  border-right 1px solid #cacaca
.authorizerange-tool
  margin 0 auto
  width 50px
.project-list, .user-list
  margin 5px auto