.title
  margin-right 10px
  font-size 16px
.search
  margin-top 30px
  display webkit-box
.search-condition, .search-middle
  display inline-block
.search-middle
  margin 0 30px
.searchbutton
  margin-top 20px
  float right
.clearfloat
  clear both

.module-com-table .grid-cell, .module-com-table .grid-row-empty
  border 1px solid #cacaca 
.grid .grid-row:nth-child(even)
  background-color #FFFFFF !important
.module-com-pager
  margin 10px auto
.rule-desc, .rule-time, .rule-detail
  color #797979
.rule-desc
  cursor pointer
  width 600px
  overflow hidden
  white-space nowrap
  text-overflow ellipsis
.rule-detail
  display none
  width 600px
  white-space normal
.rulelist-field
  padding 10px 0
  span
    display inline-block
    width 200px
  label
    color #0000FF
    cursor pointer
.rulelist-panel
  border-bottom #7892c7 solid 2px
  margin-bottom 10px
  padding 5px 0
.rulelist-tab, .rulelist-tab-active, .rulelist-tab-deactive
  font-size 10px
  font-weight bold
  padding 4px 7px
  border-radius 5px
  cursor pointer
  margin-right 10px
  color #7893C8
  display inline-block
.rulelist-tab-active
  color #FFFFFF
  background #7893C8
  position relative
.rulelist-tab-active:before
  content ""
  position absolute
  left 35%
  top 100%
  border-left 8px solid transparent
  border-top 6px solid #7893C8
  border-right 8px solid transparent

