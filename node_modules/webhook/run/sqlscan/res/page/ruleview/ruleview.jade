div
  div
    div 
      span.title SQL Scan——简单定义你的代码规则，让团队工作更加标准和高效。
      a(href="http://baike.corp.taobao.com/index.php/Sqlscan", target="_blank")什么是SQL Scan？
    div.search
      div.search-condition
        combobox(label="规则名", name="rulename", forceSelection="false", action='#{self.url.rulenames}', valuekey="name", textkey="name", labelwidth="50", placeholder="请选择规则名", page="true", pagesize="100", path="/module/com/combobox/index.js")
      div.search-middle
        combobox(label="用户名", name="owner", forceSelection="false", action='#{self.url.owners}', valuekey="email", textkey="nickname", labelwidth="50", placeholder="请选择用户名", page="true", pagesize="100", path="/module/com/combobox/index.js")
      div.search-condition
        combobox(label="应用名", name="appid", forceSelection="false", action='#{self.url.apps}', valuekey="identifying", textkey="name", labelwidth="50", placeholder="请选择应用", page="true", path="/module/com/combobox/index.js")
    div.searchbutton
      button(name="btnSearch", title="搜素规则", value="搜索", path="/module/com/form/button.js")
    div.clearfloat
  div
    div.rulelist-panel
      div.rulelist-tab
        span(class="rulelist-tab-active", value=0) 已上线
        span(class="rulelist-tab-deactive", value=1) 已删除
    div
      label(id="rulecount") 
    div
      list(name="rulelist", highlightrow="false", module="/page/ruleview/", action="./mockdata", rowtpls="rulelist",  page="true", pagesize="5", ispagestartbyindex='true', path="/module/com/list/list.js")