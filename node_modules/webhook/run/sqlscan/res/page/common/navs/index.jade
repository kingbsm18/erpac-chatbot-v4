div
  div.navbody
    if self.myTools
      each tool, i in self.myTools
        div.item
          //- button(name="#{tool.alias}", _href="#{tool.path}", _class="toolbaricon, common-btn, ticon-#{tool.alias}", title="#{tool.name}",  path="/module/newcom/button/index.js")
          div(class="btnContainer")
            a(name="#{tool.alias}", href="#{tool.path}", dataurl="#{tool.path}", class="toolbaricon common-btn ticon-#{tool.alias}", target="_blank", datatitles="#{tool.name}")
    div.setting
      button(name="pluginSetting", _class="common-btn, allplugin, js-dropdown", title="全部工具", activedclass="selplugin", value="", path="/module/newcom/button/index.js")