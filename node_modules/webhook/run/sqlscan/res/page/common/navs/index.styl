display(arguments)
  if arguments is 'flex'
    str = '-webkit-' + arguments
    display unquote(str)
  else if arguments is 'box'
    str = '-webkit-' + arguments
    display unquote(str)
  else if arguments is 'inline-box'
    str = '-webkit-' + arguments
    display unquote(str)
  else
    display unquote(arguments)
maskposition(arguments)
  -webkit-mask-position arguments
  -moz-mask-position arguments
maskimg(arguments)
  -webkit-mask-image arguments
  -moz-mask-image arguments
.toolbaricon
  maskimg(url('data:image/png;base64,'))
  background #4d4d4d
