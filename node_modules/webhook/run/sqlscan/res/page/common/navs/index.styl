.navbody
  display ('box')
  .item
    margin-right 15px
    .btnContainer
      display block
      width 28px
      height 28px
      border solid 1px #f1f1f1
      &:hover
        border solid 1px #bfbfbf
        position relative
        box-shadow inset 0 0 0.2em #bfbfbf
        background #fff
    .common-btn
      width 28px 
      height 28px
      padding 0px
      display block
    .btnsel
      background none
      maskimg(none)
      background url('data:image/png;base64,')
    .dashboardsel
      background-position 3px 3px
    .idesel
      background-position -47px 3px
    .cwfdevsel
      background-position -97px 3px
    .cwfsel
      background-position -147px 3px
    .releasesel
