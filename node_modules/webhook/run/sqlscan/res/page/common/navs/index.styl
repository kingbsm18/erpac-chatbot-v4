    .selected
      border solid 1px #bfbfbf
      position relative
      box-shadow inset 0 0 0.2em #bfbfbf
      background #fff
      &:after
        content ''
        position absolute
        top 33px
        left 6px
        background url('data:image/png;base64,') no-repeat -50px -49px
        width 10px
        height 5px
  .allplugin
    background none
    position relative
    display block
    padding 5.5px 13px
    width 28px
    height 28px
    &:after
      background url('data:image/png;base64,') no-repeat center
      background-position -47px -97px
      width 28px
      height 28px
      position absolute
      top 8px
      margin-left -6px
      content ''
    &:hover
      background #fff
      border solid 1px #bfbfbf
      box-shadow inset 0 0 0.2em #bfbfbf
