.self-setting
  margin: 10px 15px
.self-setting h4
  margin 10px 0px
.self-setting .item
  line-height: 24px
.self-setting .item span
  margin-right: 6px
.self-setting .item input[type="checkbox"]
  margin: 3px 8px 3px 10px
.self-setting .access
  margin: 5px 0px
.self-setting .access > div 
  position: relative
  height: 40px
.self-setting .access > div .info
  position: absolute
  left: 0px
  top: 6px
.self-setting .access > div input
  position: absolute
  left: 80px
  height: 24px
  width: 160px
  border: 1px solid #bfbfbf;
  &:focus
    outline: 0;
.self-setting .access > div .accesssave
  left: 260px
  position: absolute
.self-footer
  font-size: 12px
  background-color: #F5F5F5
  border-top: 1px solid #DDDDDD
  box-shadow: 0 1px 0 #FFFFFF inset
  height: 29px
  padding: 6px 20px 0px 15px
.self-footer > div
  position: relative
.self-footer > div .save
  position: absolute
.self-footer > div .cancel
  position: absolute
  left: 80px
