div.self-setting
  h4 当有以下情况时：
  infos = ["有人邀请我回答一个问题", "我关注的问题有了新回答", "问题或回答有我负责的表"]
  names = ["J_questionInvite", "J_attentionAnswer", "J_appearTable"]
  types = ["站内消息", "旺旺消息", "邮件消息"]
  alias = ["inviteAnswer", "attentionAnswer", "appearTable"]
  each item, i in infos
    div(data="#{alias[i]}", class="item")
      span #{item}
      each t, j in types
        input(type="checkbox", value="#{j}", name="#{names[i]}")
        label #{t}
  h4 设置AccessKey和AccessId：
  div.access
    div
      div.info
        span Access ID 
        font(color="red") *
      input(class="access_id", name="accessId", placeholder="请输入AccessId")
    div
      div.info
        span Access Key 
        font(color="red") *
      input(class="access_key", name="accessKey", placeholder="请输入AccessKey")
      button(class="normal-btn accesssave", btntype="primary", name="btnSaveAccess", value="保存", path="/module/com/form/button.js") 
div.self-footer
  div
    button(class="normal-btn save", name="btnSave", btntype="primary", value="保存", path="/module/com/form/button.js")
    button(class="normal-btn cancel", name="btnCancel", value="取消")