div.window-feedback
  div.issue-title
    span.feedback-problem.active-title 反馈问题
    span.feedback-require 反馈需求
  div.issue-body
    textarea(placeholder="遇到了问题？                                                                                                     想要新功能？                                                                                                    仅仅发发牢骚？                                                                                                     还是想夸奖我们(*^__^*)？                                                                                 都可以写在这里，我们会尽快回应的")
    div.issue-body-bottom
      span 嗨，心情怎么样？
      input(type="radio", name="feeling", value="愤怒")
      span 愤怒
      input(type="radio", name="feeling", value="不满")
      span 不满
      input(type="radio", name="feeling", value="平静", checked="checked")
      span 平静
      input(type="radio", name="feeling", value="挺好")
      span 挺好
      input(type="radio", name="feeling", value="开心")
      span 开心
  div.issue-bottom
    span.his-issue-list 我的历史反馈
    div
      button(class="submit-btn", btntype="success", name="doSubmitBtn", value="提交", title="", path="/module/com/form/button.js")
    div
      button(class="cancel-btn", name="doCancelBtn", value="取消", title="", path="/module/com/form/button.js")
