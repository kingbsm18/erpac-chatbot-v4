.windowpanel
  text-align left
  padding 0
  margin auto
  background  #f8f8f8
  border solid 1px #bfbfbf
  display -webkit-flex
  -webkit-flex-flow column
  overflow hidden
  position absolute
  z-index 99999
  box-shadow 0 2px 10px rgba(0, 0, 0, .2)
  -webkit-transition -webkit-trandform,opacity
  // opacity 0 
.windowpanel .title
  margin-top 1px
  height 23px
  background #f3f3f3
  cursor move
  padding 6px 12px
  border-bottom solid 1px #bfbfbf
.windowpanel .title .title-text
  margin 3px
  line-height 20px
.windowpanel .window-body
  -webkit-flex 1
.overlay
  position fixed
  top 0px
  left 0px
  width 100%
  height 100%
  opacity 0.2
  background rgb(0, 0, 0)
  z-index 99
  display block
.windowpanel .title .close
  float right
  font-size 20px
  font-weight bold
  line-height 20px
  color #000
  text-shadow  0 1px 0 #ffffff
  opacity 0.2 
  margin-top 2px
  padding 0
  cursor pointer
  background transparent
  border 0
  -webkit-appearance none

.fieldset
  border 1px solid #b5b8c8
  padding 10px
  margin 10px
  legend div
    color #15428b
    margin 0 10px
.odpsAccessKeyInfo
  > div
    margin 10px 0
    line-height 20px
    > label
      display inline-block