@import '../fn'
@import '../common'
header_info_height = 64px
line_height = 12px
header_nav_margin = 15px
font_size = 12px
header_nav_height = 37px
nav_search_width = 202px
nav_search_height = 25px

ol, ul
  padding 0px
  margin 0px
input[type="text"]
  padding-top: 0px
  padding-bottom: 0px
header_layout()
  width: 980px
  margin: 0 auto
  position: relative
header_info_li(_color)
  float: left
  font: font_size/1 '微软雅黑'
  padding: 0 20px 0px 10px
  line-height: line_height
  border-right: 1px solid #dedede
  color: _color
  cursor: pointer
inverted_triangle(_color)
  border-left:transparent solid 4px
  border-right:transparent solid 4px
  border-top: _color solid 4px
  position: absolute
  top: 3px
  margin-left: 3px
  content ''
  position absolute
header_gbm()
  z-index: 9999999
  position: absolute
  top: 15px
  left: 10px
  background: #fff
  width: 100px
  border: 1px solid #1793eb
  padding: 10px 0px
  display: none
  box-shadow 0 2px 4px rgba(0,0,0,.2)
.gbm
  header_gbm()
  ol li
    border: none
    line-height: 27px
    &:hover
      background: #D6E9F8
    a
      text-decoration: none
      padding: 3px 25px
      color: #666
.app-list
  width 224px
  height auto
  padding 5px 0px
  border 1px #d9d9d9 solid
  background white
  position absolute
  display none
  z-index 9999999
  box-shadow 0 2px 4px rgba(0,0,0,.2)
  .app-item
    position relative
    margin 5px 0px
    height 33px
    cursor pointer
    &:hover
      background #D6E9F8
    img
      position absolute
      top 0px
      left 10px
    .content
      position absolute
      margin-left 50px
      margin-top 8px
  .app-more
    text-decoration none
    display block
    padding 5px
    color #111
    text-align center
    &:hover
      background #D6E9F8

.logo-info
  header_layout()
  height: header_info_height
  .logo
    width: 142px
    height: 62px
    position: absolute
    left: -4px
  ul
    float: right
    position: absolute
    right: 0
    top: (header_info_height - line_height - header_nav_margin)  
    li
      header_info_li(#666)
      span > label
        cursor: pointer
      span > label:after
        inverted_triangle(#666)
    .msg
      cursor: pointer
    .control
      cursor: pointer
    .end
      border: none  
.logo-newinfo
  header_layout()
  height: header_info_height
  .logo
    width: 142px
    height: 62px
    position: absolute
    left: -4px
    cursor: pointer
  .loginAll
    position absolute
    right 0px
    display(box)
    top 20px
    width 130px
    height 28px
    .message, .setting
      background none
    .doc, .mail
      width 28px
      height 28px
      padding 5.5px 13px
      margin-right 10px
      &:after
        content ''
        position absolute
        width 1px
        height 10px
        border-right solid 1px #ccc
        top 9px
        left 29px
    .mail:after
      left 70px
    .setting
      color #9c9c9c
      padding 5.5px 8px
      &:after
        border-left transparent solid 4px
        border-right transparent solid 4px
        border-top #666 solid 4px
        position absolute
        top 11px
        margin-left 3px
        content ''
    .notify:before
      content ''
      position absolute
      top 6px
      margin-left 3px
      border solid 1px red
      border-radius 5px
      background red
      width 3px
      height 3px
.navfixed
  position: fixed
  width: 100%
  z-index: 99
  top: 0px
.global-nav
  background: #1897f2
  height: header_nav_height
  width 100%
  position fixed
  &.cheetahDocument
    .document-menu
      display block
  .document-menu
    position relative
    display none
    height 39px
    background #F2F2F2
    border-bottom 1px solid #FFFFFF
    ul
      width 980px
      margin 0 auto
      li
        float left
        padding 12px
        margin-right 12px
        a
          text-decoration none
          color #44B2FC
          font-size 14px
          font-family Heiti SC
    // &:after
    //   position absolute
    //   top -5px
    //   left 552px
    //   content ''
    //   border-left transparent solid 5px
    //   border-right transparent solid 5px
    //   border-bottom #F2F2F2 solid 5px
    .sub-active
      font-weight bold
      color #008CE9
  .min-logo
    float: left
    height: 37px
    display: none
    margin-left: -8px
  .nav-items
    list-style: none
    padding: 0
    li
      a
        display: block
        max-height: header_nav_height
        font: fs = (font_size + 2px)/1 '微软雅黑'
        color: #fff
        font-weight: normal
        text-transform: uppercase
        letter-spacing: 1px
        padding: ((header_nav_height - fs) / 2) 18px ((header_nav_height - fs) / 2)
        cursor: pointer
        text-decoration: none
  .container
    header_layout()
    ul 
      li
        float: left
        position relative
        &:hover
          background: #0b83d9
      .active:after
          content ''
          position absolute
          top 33px
          left 45%
          border-left transparent solid 5px
          border-right transparent solid 5px
          border-bottom #fff solid 5px
    .nav-search
      position: absolute
      right: 0px
      .top
        width: (nav_search_width - 2)
        height: nav_search_height
        margin: ((header_nav_height - @height) / 2) 0px
        border: 1px solid #1793eb
        position: relative
        background: #fff
        input
          position: absolute
          left: 0px
          height: nav_search_height
          padding-left: 7px
          padding-right: @padding-left
          width: (nav_search_width - (@padding-left * 2 + 15px))
          border: none
          outline: none
        .icon
          width: 15px
          height: 15px
          background-position: -200px -50px
          position: absolute
          right: 4px
          top: ((nav_search_height - @height) / 2)
      .bar-items
        border: 1px solid #1793eb
        width: (nav_search_width - 2px)
        position: absolute
        top: 32px
        background: #fff
        display: none
        overflow: hidden
        z-index: 999
        ul li
          text-align: left
          line-height: 30px
          margin: 0px
          padding: 0px 7px
          width: 100%
    .info
      position absolute
      z-index 100
      right 0px
      top 12.5px
      display none
      >li
        color: #fff
        float left
        padding 0px 20px 0px 10px
        border-right 1px solid #dedede
        line-height 12px
        cursor pointer
        &:hover
          background #1897f2        
        a
          padding: 3px 12px
          color: #fff
          font-size 12px

          &:hover
            background #1897f2
        span > label
          cursor: pointer
        span > label:after  
          inverted_triangle(#fff)
      >.end
        border none
      .help
        a
          text-decoration none
          padding 0
          .help-text
            background url('/img/help-white.png') no-repeat 0 50%
            padding-left 17px
.sprite
  background: url(/img/icon.png) no-repeat top left