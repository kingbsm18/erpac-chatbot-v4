*
  margin 0px
  padding 0px
ol, ul
  list-style none
.container
  min-height 100%
  height 100%
  height auto
  position relative
.header
  width 100%
.body
  display flex
  flex-flow row
  width bodyWidth
  margin 0 auto
  margin-top 20px
  padding-bottom (bottomHeight + 20px)
.footer
  background #f5f5f5
  left 0px
  right 0px
  bottom 0px
  position absolute
  height bottomHeight
  clear both
  color #666
  font-size 14px
  border-top 1px solid #d9d9d9
  .wrapper
    height 102px
    width bodyWidth
    margin 0 auto
    a
      text-decoration none
      color #666
    .relation
      border-bottom 1px solid #d9d9d9
      height 50px
      position relative
      ul
        position absolute
        left 0px
        top ((@height - 14px) / 2)
        li
          float left
          padding 0px 8px
          border-right 1px solid #d9d9d9
        .end
          border none
      // .powered
      //   position absolute
      //   right 0px
      //   top ((@height - 14px) / 2)
      // .pe
      //   position absolute
      //   right 0px
      //   top ((@height + 12px) / 2)
    .copyright
      text-align center
      margin-top (((@height - 14px) / 2) / 2)
      a
        margin-left 10px
        border-left 1px solid #d9d9d9
        padding-left 10px

.hide
  display none!important
.clear-fix
  clear both

.feed_back_fixed
  background-image url(/img/feedback.png)
  background-repeat no-repeat
  position fixed
  cursor pointer
  display inline-block
  right 0px
  width 15px
  height 70px
  padding 10px

.page_ask_fixed
  background-image url(/img/ask.png)
  background-repeat no-repeat
  background-size  auto auto
  border-style none
  height  90px
  width  35px
  right 0px
  z-index 1546451561
  font-size  12px
  text-align  center
  position  fixed
  _position  absolute
  top  100px
  _bottom  "auto"
  cursor  pointer
  display  block

.robot_fixed
  background-image url(/img/robot.jpg)
  background-repeat no-repeat
  background-size  auto auto
  position fixed
  cursor  pointer
  right 0px
  bottom 0px
  width 75px
  height 85px

#scrollTopBtn
  display none
  position fixed
  right 10px
  bottom 200px
  z-index 9999
  width 50px
  height 50px
  border-radius 5px
  background #E7E7E7
  cursor pointer
  &:after
    position absolute
    top 15px
    left 15px
    content ''
    border-left transparent solid 10px
    border-right transparent solid 10px
    border-bottom #c9c9c9 solid 16px
