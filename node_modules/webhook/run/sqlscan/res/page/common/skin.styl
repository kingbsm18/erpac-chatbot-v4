.grid
  border-top 3px solid RGB(24, 151, 242)
  border-bottom 1px solid RGB(217, 217, 217)
  .grid-header
    border-bottom 1px solid RGB(217, 217, 217)
  .grid-row
    &:last-child
     border-bottom 0
    &:nth-child(even)
      background-color #FFFFFF
.module-com-table .grid-row
  border-bottom 1px solid #e5e5e5
.module-com-table .grid-footer
.pagebar
  height 40px
  display box
  box-pack center
  box-align center
  button
    color #666
    border 1px solid #ccc
    background-color #fff
    margin 10px
    padding 0 10px
    line-height 24px
    height 24px
  input
    margin 10px 0 10px 10px

.field
  margin 5px 0
.windowpanel
  border: 2px solid #737373 !important
.windowpanel .title
  font-weight: bold
  background: #ededed !important
  border-bottom: 1px solid #d9d9d9 !important
.windowpanel .title .close
  color: #888 !important
  opacity: 1.2 !important