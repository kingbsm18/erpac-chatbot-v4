div
  div.pluginBody
    div.top
      button(name="btnSetting", _class="link, setting", showtip="false", title="设置常用工具", value="设置常用工具", path="/module/newcom/button/index.js")
    div.pbody
      if self.pluginList
        each plugin, i in self.pluginList
          div(class="item #{plugin.alias}")
            div.top #{plugin.name}
            div.content
              ul
                if plugin.children
                  each child, j in plugin.children
                    li
                      checkbox(name="#{child.alias}",_href="#{child.path}", alias="#{child.alias}", _class="plugin_check, #{child.alias}", title="#{child.name}", value="#{child.id}", path="/module/newcom/checkbox/index.js")
    div.bottom
      div.iconcontainer
        div.pluginicon
      div.plugindesc
        div.desc
        div.info
          div.team 
      div.photo