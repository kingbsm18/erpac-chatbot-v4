- var updateTime = self.updated_at.replace('T',' ').replace('Z','')
div.issue-row
  div
    label 标题 
    a(class="issue-title", target="_blank", href="http://gitlab.taobao.ali.com/ouya.zxx/userissues/issues/#{self.id}") #{self.title}
  div
    if (self.milestone && self.milestone.title)
      label 状态
      span.issue-state #{self.milestone.title}
    else
      label 状态
      span.issue-state 未处理
    label 修改时间
    span.issue-time #{updateTime}
  div
    if self.labels.length*1 > 0
      label 标签
      span.issue-label #{self.labels}
    
