div
  div.createresource
    div.createresource-field
      div.createresource-field-name 脚本名：
      div.createresource-field-value
        field(name="scriptName", regex="^[A-Za-z][A-Za-z0-9_]*$", allowblank="false", invalidtext="请输入由字母数字下划线构成，字母开头的名称", placeholder="为脚本命名，更好的识别和理解", path="/module/com/form/field.js")
    div.createresource-field
      div.createresource-field-name 文件：
      div(class="createresource-field-value sqlScanUploadFile")
        input(type="file")
        label * 请选择文件
    div.createresource-field
      div.createresource-field-name 脚本类型：
      div.createresource-field-value
        combobox(name="scriptType", placeholder="请选择脚本类型", allowblank="false", path="/module/com/combobox/index.js")
    div.createresource-field
      div.createresource-desc
        textareafield(name="scriptDesc", label="脚本描述", labelwidth="90", height="100", allowblank="false", placeholder="描述你的脚本，让使用者更好理解，如： XXXXXX", path="/module/com/form/textarea.js")
    div.createresource-tool
      div.createresource-btn-left
        button(name="btnCreateResourceSure", title="创建", value="创建", path="/module/com/form/button.js")
      div.createresource-btn-right
        button(name="btnCreateResourceCancel", title="取消", value="取消", path="/module/com/form/button.js")
