- var rank = '提醒', variable = '关闭', detail = self.detail
if self.rank == 2
  rank = '禁止'
if self.replaceParamStatus == 0
  variable = '开启'
if detail.length > 50
  detail = detail.substr(0,45) + '...'
div.rulemanage
  div.rulemanage-list
    div.rulemanagelist-field  #{self.id} #{self.name}
    div.rulemanagelist-field
      span 创建人： #{self.author}
      span 限制等级: #{rank}
      label(value="authorization") 授权范围
      if self.status === 1
        if self.isOwner
          button(class="btnRestore") 恢复
          button(class="btnUpdate") 编辑
        else
          button(class="btnRestore", disabled="disabled") 恢复
          button(class="btnUpdate", disabled="disabled") 编辑
      else
        if self.isOwner
          button(class="btnDelete") 删除
          button(class="btnUpdate") 编辑
        else
          button(class="btnDelete", disabled="disabled") 删除
          button(class="btnUpdate", disabled="disabled") 编辑
    div.rulemanagelist-field
      div.rule-time
        span 变量强制替换: #{variable}
        span 更新时间： #{self.updatedAt}
        span 创建时间： #{self.createdAt}
    div.rulemanagelist-field
      div
        div.rule-desc #{detail}
        div.rule-detail #{self.detail}

