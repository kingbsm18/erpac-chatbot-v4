.title
  font-size 16px
.search
  margin 20px 0
  display webkit-box
.search-condition
  width 300px
  display inline-block
.searchbutton
  float right

.row-show
  border 1px solid #cacaca 
.grid-base-row
  margin 10px 0
.grid .grid-row:nth-child(even)
  background-color #FFFFFF !important
.module-com-pager
  margin 10px auto
.ruleproject
  width 680px
.ruleproject-list
  width 660px
.ruleprojectlist-field
  padding 10px 0
  span
    display inline-block
    width 200px
  label
    color #0000FF
    cursor pointer
  button
    float right
    margin-right 10px
    width 60px
.ruleprojectlist-panel
  border-bottom #7892c7 solid 2px
  margin-bottom 10px
  padding 5px 0
.ruleprojectlist-tab, .ruleprojectlist-tab-active, .ruleprojectlist-tab-deactive
  font-size 10px
  font-size 10px
  font-weight bold
  padding 4px 7px
  border-radius 5px
  cursor pointer
  margin-right 10px
  color #7893C8
  display inline-block
.ruleprojectlist-tab-active
  color #FFFFFF
  background #7893C8
  position relative
.ruleprojectlist-tab-active:before
  content ""
  position absolute
  left 35%
  top 100%
  border-left 8px solid transparent
  border-top 6px solid #7893C8
  border-right 8px solid transparent

