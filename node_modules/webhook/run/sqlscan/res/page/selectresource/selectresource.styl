.module-com-pager
  margin 0 auto
.selectresource-body
  margin 20px
.title-select, .title-btn
  display inline-block
  margin-right 30px
.title-select
  width 300px
.title-btn
  width 100px
.grid-viewport
  height 370px
.selectresource-list
  margin 20px 0
  border 1px solid #cacaca 
.sourcelist
  width 100%
.sourcelist-fie
  padding 8px 0
  display -webkit-flex
.sourcelist-name, .sourcelist-value
  -webkit-flex 1
  text-overflow ellipsis
  overflow hidden
  white-space nowrap
  margin-right 10px
.sourcelist-name, .sourcelist-desc
  color #cacaca
.sourcelist-desc
  -webkit-flex 3
  margin-right 30px
  text-overflow ellipsis
  overflow hidden
  white-space nowrap
.selectresource-tool
  width 200px
  margin 0 auto
  clear both
.selectresource-btn-left
  float left
.selectresource-btn-right
  float right