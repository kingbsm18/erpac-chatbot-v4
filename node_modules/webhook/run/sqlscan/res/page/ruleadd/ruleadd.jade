div
  div
    div.ruleadd-field 
      span.title 配置一条代码规则，选择适用于哪些人。
    div.ruleadd-field
      div.field-name 规则名：
      div.field-value
        field(name="rulename", regex="^[A-Za-z][A-Za-z0-9_]*$", invalidtext="请输入由字母数字下划线构成，字母开头的名称", value="#{self.ruleInfo.ruleBean.name ? self.ruleInfo.ruleBean.name : ''}", allowblank="false", labelwidth="80", placeholder="为规则命名，更好的识别和理解", path="/module/com/form/field.js")
    div.ruleadd-field
      div.field-name 资源：
      div.field-value
        div.field-value-button
          input(id="sqlScanResourceId", readonly="true", value="#{self.ruleInfo.ruleBean.resourceName ? self.ruleInfo.ruleBean.resourceName : ''}", placeholder="请选择资源名")
        div.field-value-button
          button(name="btnSource", title="选择资源", value="选择资源", path="/module/com/form/button.js")
        div.field-value-button
          button(name="btnCreate", title="创建资源", value="创建资源", path="/module/com/form/button.js")
        div.field-value-button
    div.ruleadd-field
      div.field-name-none 限制等级：
      div.field-value
        div.field-value-button
          if !self.ruleInfo.ruleBean.rank || self.ruleInfo.ruleBean.rank === 1
            input(type="radio", name="ruleRank", value=1, checked="true")
          else
            input(type="radio", name="ruleRank", value=1)
          label 提醒
        div.field-value-button
          if self.ruleInfo.ruleBean.rank == 2
            input(type="radio", name="ruleRank", value=2, checked="true")
          else
            input(type="radio", name="ruleRank", value=2)
          label 禁止
    div.ruleadd-field
      div.field-name-none 变量强制替换：
      div.field-value
        div.field-value-button
          if !self.ruleInfo.ruleBean.replaceParamStatus || self.ruleInfo.ruleBean.replaceParamStatus === 1
            input(type="radio", name="ruleVariable", value=1, checked="true")
          else
            input(type="radio", name="ruleVariable", value=1)
          label 关闭
        div.field-value-button
          if self.ruleInfo.ruleBean.replaceParamStatus == 0
            input(type="radio", name="ruleVariable", value=0, checked="true")
          else
            input(type="radio", name="ruleVariable", value=0)
          label 开启
    div.ruleadd-field
      div.field-name 规则授权：
      div.field-value
        div.authorizecontainer
          - var authorizes = self.ruleInfo.users
          for items in authorizes
            items = JSON.stringify(items)
            authorizeitem(name="test",value="#{items}", path="/page/ruleadd/authorizeitem/authorizeitem.js")
        div
          button(name="btnAddAuthorize", title="添加授权", value="+", path="/module/com/form/button.js")
    div.ruleadd-field
      div.field-name 规则描述：
      div.field-value
        textareafield(name="ruledesc", height="100", value="#{self.ruleInfo.ruleBean.detail ? self.ruleInfo.ruleBean.detail : ''}", allowblank="false", labelwidth="80", placeholder="描述你的规则，让使用者更好理解，如： 规范表名，表名必须以abcd开头", path="/module/com/form/textarea.js")
    div.ruleadd-field
      div.field-name
      div.field-value
        div.field-value-button
          button(name="btnAdd", title="添加规则", value="#{self.ruleInfo.ruleBean.name ? '更新配置' : '确定添加'}", path="/module/com/form/button.js")
        div.field-value-button
          button(name="btnCancel", title="取消", value="取消", path="/module/com/form/button.js")



