.container
  background RGB(245, 245, 245)
  border 1px solid RGB(237, 237, 237)
  padding 5px 0
  .menu
    ul
      padding 0
      margin 0
      li
        list-style none
      .item
        a
          color RGB(102, 102, 102)
          text-decoration none
          line-height 27px
          display inline-block
          padding-left 9px
        &.parent > a
          color #000000
          padding-left 0px
          font-weight bold
        &.parent > .arrow
          display inline-block
          width 0
          height 0
          vertical-align top
          border-top 4px solid RGB(102, 102, 102)
          border-right 4px solid transparent
          border-left 4px solid transparent
          margin 10px 5px 0 5px
        &.parent > ul > li
          padding-left 20px
      .active
        background RGB(24, 151, 242)
        a
          color #FFFFFF
      .sprite
        border-top 1px solid RGB(217, 217, 217)
        height 0px
        margin 5px 10px