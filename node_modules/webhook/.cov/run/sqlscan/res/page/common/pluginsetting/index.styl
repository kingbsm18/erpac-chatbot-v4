box-flex()
  -webkit-box-flex arguments
  -moz-box-flex arguments

display(arguments)
  if arguments is 'flex'
    str = '-webkit-' + arguments
    display unquote(str)
  else if arguments is 'box'
    str = '-webkit-' + arguments
    display unquote(str)
  else if arguments is 'inline-box'
    str = '-webkit-' + arguments
    display unquote(str)
  else
    display unquote(arguments)
maskposition(arguments)
  -webkit-mask-position arguments
  -moz-mask-position arguments
maskimg(arguments)
  -webkit-mask-image arguments
  -moz-mask-image arguments
picon()
  maskimg(url('data:image/png;base64,'))
  height 20px
  line-height 20px
  padding 8px 15px
  background #4d4d4d
ots()
  content '第三方'
  top 32px
  left -5px
  position absolute
  border solid 1px #ff720d
  background #ff720d
  color #fff
  width 40px
  font-size 12px
  padding 2px
  border-radius 2px
  text-align center
picon2()
  maskimg(url('data:image/png;base64,'))
  position relative
  background #4d4d4d
maskimg(arguments)
  -webkit-mask-image arguments
  -moz-mask-image arguments
maskposition(arguments)
  -webkit-mask-position arguments
  -moz-mask-position arguments
.pluginBody
  width 684px
  .top
    text-align right
    height 44px
    margin-left 40px
    .btnContainer
      margin-top 20px
      position absolute
      right 20px
      border solid 1px #bfbfbf
      &:hover
        background #ff720d
        border solid 1px #ff720d
    .setting
      line-height 14px
      color #333
      position relative
      padding-right 0px
      background #fff
      padding 4px 10px 4px 25px
      text-decoration none
      &:hover
        background #ff720d
        color #fff
        &:before
          background #fff
          maskposition(-150px -100px)
          maskimg(url('data:image/png;base64,'))
      &:before
        content ''
        background url('data:image/png;base64,') no-repeat center
        background-position -150px -100px
        position absolute
        left 7px
        width 13px
        height 13px
    .selected
      line-height 14px
      padding-right 0px
      background #ff720d
      border solid 1px #ff720d
      button
        color #fff
        padding 4px 6.5px
        background #ff720d
        &:hover
          text-decoration none
  .pbody
    display('box')
    margin-top 40px
    margin-bottom 50px
    .item
      box-sizing(border-box)
      width 170px //160
      height auto
      border-left dashed 1px #bfbfbf
      &:first-child
        border none
      .top
        text-align left
        font-weight bold
        font-size 13px
        margin-top 20px
        margin-bottom 16px
        color #666
        height 14px
        font-family '宋体'
      .content ul
        list-style none
        padding 0px
        margin 0px
        font-size 12px
        li
          line-height 36px
          color #666
          font-family '宋体'
          a
            text-decoration none
            display block
            overflow hidden
            white-space nowrap
            text-overflow ellipsis
          &:hover
            background #f1f1f1
          .plugin_check
            display block
            &:before
              margin-left 35px
          .appConfig:before
            picon()
            maskposition(-297px 3px)
          .dashboard:before
            picon()
            maskposition(3px 3px)
          .ide:before
            picon()
            maskposition(-47px 3px)
          .cwfdev:before
            picon()
            maskposition(-97px 3px)
          .cwf:before
            picon()
            maskposition(-147px 3px)
          .release:before
            picon()
            maskposition(-197px 3px)
          .mosad:before
            picon()
            maskposition(-247px 3px)
          .dqc:before
            picon()
            maskposition(-347px 3px)
          .gitlab:before
            picon()
            maskposition(-97px -47px)
          .birdmanmate:before
            picon()
            maskposition(-147px -47px)
          .odpsConsole:before
            picon()
            maskposition(-247px -47px)
          .Sqlscan:before
            picon()
            maskposition(-347px -47px)
          .check, .checked, .disabled
            margin-left 0px 
          .check:after
            background-color #fff
            width 15px
            height 15px
            border solid 1px #bfbfbf
            content ''
            position absolute
            left 10px
            top 8px
          .checked:after
            background url('data:image/png;base64,') no-repeat -198px -97px
            background-color #54ba1c
            width 15px
            height 15px
            border solid 1px #54ba1c
            content ''
            position absolute
            left 10px
            top 8px
          .disabled
            opacity 0.5
            &:after
              background-color #f1f1f1
              width 15px
              height 15px
              border solid 1px #ccc
              content ''
              position absolute
              left 10px
              top 8px
