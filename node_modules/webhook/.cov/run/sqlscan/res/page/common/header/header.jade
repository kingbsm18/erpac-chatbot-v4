div
  div(class="logo-info", style="display:none;")
    img(src="/img/index/logo.png", class="logo")
    block ulInfo
      ul.info
        if self.helpUrl
          li.help
            a(target="_blank", href="#{self.helpUrl}")
              div.help-text 帮助
        li.curinfo 
          span
            label #{self.nick}
        li(class="curapp end", style="display:block;")
          span
            label(title="所有应用") 所有应用
  
  div.logo-newinfo
    img(src="/img/index/logo.png", class="logo")
    div(class="loginAll")
      div
        button(name="doc", _class="toolbaricon, ticon-doc, doc, js-dropdown", showtip="false", hoverclass="", activedclass="selected", title="xx", value="", path="/module/newcom/button/index.js")
      div
        button(name="message", _class="toolbaricon, ticon-mail, mail, js-dropdown", showtip="false", hoverclass="msgover", activedclass="selected", title="xx", value="", path="/module/newcom/button/index.js")
      div
        button(name="setting", _class="setting, js-dropdown", activedclass="selected", showtip="false", title="xx", value="#{self.nick}", path="/module/newcom/button/index.js")
  div.global-nav
    div.container
      a(href='#{self.config[0].href}')
        img(src="/img/logodxpmin.png", class="min-logo")
      ul.nav-items
        each item, i in self.config
          li(data="#{item.value}")
            if item.value === 'atatech'
              a(href="#{item.href}", target="_blank") #{item.alias}
            else
              a(href="#{item.href}") #{item.alias}
      div.nav-search(style="display: none")
        div.top
          input(class="search-input", placeholder="搜索应用、数据或文档...", type="text")
          span(class="icon sprite")
        div.bar-items
          ul
            each item, i in self.searchConfig
              li(data-value="", data-index="#{i}")
                font 在 
                font #{item} 
                font 中搜索
      block append ulInfo
    div.sub-menu.document-menu
      ul
        li
          a(href="/s/cheetah/document/guide") 使用指南
        li
          a(href="/s/cheetah/document/technology") 技术指南
        li
          a(href="/s/cheetah/document/api") API文档
        li
          a(href="/s/cheetah/document/history") 历史版本
  div(class="placeholder_div", style="height:37px;visibility: hidden;")
  div.gbm
    ol
      li
        a(class="userinfo", href="javascript:void(0)") 个人信息
      li(style="display:none")
        a(class="msg", href="javascript:void(0)") 消息
      li(style="display:none")
        a(class="control", href="javascript:void(0)") 设置
      li
        a(class="loginout", href="/s/logout") 退出
  div.app-list