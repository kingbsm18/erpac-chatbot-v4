.window-feedback 
  padding 15px 10px
  font 12px '宋体'
  .issue-title span
    cursor pointer
    color rgba(0, 0, 0, 0.5)
  .issue-title .active-title
    font-weight bold
    color rgb(0, 0, 0)
  .feedback-problem
    padding-right 20px
    border-right 1px solid rgba(0, 0, 0, 0.3)
  .feedback-require
    padding-left 20px
  textarea
    width 450px !important
    margin-top 15px
    height 175px !important
    padding 5px
  textarea:focus
    outline none
  .issue-body-bottom
    width 100%
    padding 14px 0px
    border 1px solid rgba(0, 0, 0, 0.3)
    margin-top -3px
    background-color rgba(250, 236, 236, 0.5)
    > span
      margin-left 10px
    input
      margin-left 20px
  .issue-bottom
    margin-top 10px
    display -webkit-box
    .his-issue-list
      cursor pointer
      display inline-block
      margin-top 10px
      margin-left 240px
      color #1897f2
    .submit-btn
      margin-left 35px
    .cancel-btn
      margin-left 19px
  .create-issue-return
    width 100%
    height 240px
    > span
      padding-left 100px
      margin-top 100px
      display inline-block