$        = require 'jquery'
FeedBack = require '../feedback/feedback'

class Helper
  constructor : (option)->
    @setStyleTag('.feed_back_fixed {background: url("data:image/png;base64,") no-repeat 50% 50%; background-repeat: no-repeat; position: fixed; cursor: pointer; display: inline-block; right: 0; width: 15px; height: 70px; padding: 10px;} .page_ask_fixed {background: url("data:image/png;base64,") no-repeat 50% 50%; background-repeat: no-repeat; background-size: auto auto; border-style: none; height: 90px; width: 35px; right: 0; z-index: 1546451561; font-size: 12px; text-align: center; position: fixed; _position: absolute; top: 100px; _bottom: "auto"; cursor: pointer; display: block;} .robot_fixed {background: url("data:image/png;base64,") no-repeat 50% 50%; background-repeat: no-repeat; background-size: auto auto; position: fixed; cursor: pointer; right: 0; bottom: 0px; width: 75px; height: 85px;}')
    body = $ document.body
    # 起始高度等于页面高度减去每个组件的高度除以2，再减去底部的高度 
    top = (document.body.clientHeight - 100 * 2)/2 - 50
    body.append @createFeedBack top, option
    top = top + 100
    body.append @createSupport top
    body.append @createRobot()

  createFeedBack : (top, option)->
    left = document.body.clientWidth - 540
    feedbackDiv = $ '<div class="feed_back_fixed" style="top: ' + top + 'px;"></div>'
    feedbackDiv.on 'click.create',()->
      feedback = FeedBack._create
        userInfo : option.user
        prefix : option.prefix
        drag : false
        modal : false
        left : left
        top : Math.max(top - 80, 0)
      feedbackDiv.unbind 'click.create'
    feedbackDiv

  createSupport : (top)->
    $ '<a href="http://www.taobao.com/webww/?ver=1&&touid=cntaobaodxp技术支持&siteid=cntaobao&status=2&portalId=&gid=&itemsId=" target="_blank">
      <div class="page_ask_fixed" style="top: ' + top + 'px;"></div></a>'

  createRobot : ->
    $ '<a href="http://service.taobao.com/support/minerva/beta_robot_main.htm?sourceId=1319111315" target="_blank">
      <div class="robot_fixed"></div></a>'

  setStyleTag : (css) ->
    dom = document.createElement('style')
    dom.appendChild(document.createTextNode(css))
    document.head.appendChild(dom)

exports = module.exports = Helper