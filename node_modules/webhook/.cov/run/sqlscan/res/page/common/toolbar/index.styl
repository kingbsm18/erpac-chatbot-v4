*
  font-size 12px
  margin 0px
  padding 0px
div:focus
  outline none
.toolbaricon
  background url('data:image/png;base64,') no-repeat 50% 50%
.ticon-mail
  background-position -197px -47px
.ticon-doc
  background-position -297px -47px
.module-newcom-popover
  margin 0px
  padding 0px
.mininav
  background #F1F1F1  //#F2F2F2
  width 100%
  height 48px
  border-bottom solid 1px #BFBFBF
  .container
    margin 0 auto
    position relative
    display('box')
    width 980px
    .logo, .delimiter, .app, .navs, .search, .loginAll
      -moz-box-sizing border-box
      -webkit-box-sizing border-box
    .logo
      border none
      background url('data:image/png;base64,') no-repeat 50% 50%
      width 116px
      height 48px
      cursor pointer
    .app
      width 268px
      margin 10px 10px 9px 75px
      .label
        padding 8px 0
        margin-right 5px
        font-weight bold
      .field-head .arrow
        padding 0px 10px
        background #fff
      .allApp
        width 183px
        height 26px
        padding-left 10px
        border solid 1px #bfbfbf
      .myAppItem
        height 27px
        .icon-container
          padding-right 0px
          padding-left 5px
    .delimiter
      border-right solid 1px #BCBCBC
      height 25px
      margin 11.5px 5px
    .navs
      width 268px
      height 28px
      margin 10px 10px 10px 15px
    .loginAll
      width 130px
      height 28px
      margin 10px 0px
      position absolute
      right 0px
      display('box')
      .message, .setting
        background none
      .doc, .mail
        width 30px
        height 28px
        padding 5.5px 13px
        margin-right 10px
      .setting
        color #9c9c9c
        padding 5.5px 0px
        &:after
          border-left transparent solid 4px
          border-right transparent solid 4px
          border-top #666 solid 4px
          position absolute
          top 11px
          margin-left 3px
          content ''
      .notify:after
        content ''
        position absolute
        top 6px
        margin-left 3px
        border solid 1px red
        border-radius 5px
        background red
        width 3px
        height 3px


