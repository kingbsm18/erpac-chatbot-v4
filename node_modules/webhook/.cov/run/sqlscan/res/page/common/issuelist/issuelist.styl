.window-issuelist
  padding 10px
  .issue-table
    width 460px
  .grid-viewport
    height 256px
  .issue-row
    width 400px
    div
      margin-top 10px
      label
        color #888
  .issue-title
    display inline-block
    overflow hidden
    white-space nowrap
    text-overflow ellipsis
    width 350px
    margin-left 20px
    text-decoration none
  .issue-state, .issue-time, .issue-label
    padding 0px 20px