div
  div
    div 
      span.title 查看、编辑你的规则（仅开放给应用owner、和应用运维人员）
    div.search
      div.search-condition
        combobox(label="规则名", name="rulename", forceSelection="false", action='#{self.url.rulenames}', valuekey="name", textkey="name", labelwidth="50", placeholder="请选择规则名", page="true", pagesize="100", path="/module/com/combobox/index.js")
      div.search-middle
        combobox(label="创建人", name="owner", forceSelection="false", action='#{self.url.owners}', valuekey="email", textkey="nickname", labelwidth="50", placeholder="请选择创建人", page="true", pagesize="100", path="/module/com/combobox/index.js")
      div.search-condition
        combobox(label="限制等级", name="rank", labelwidth="60", placeholder="请选择限制等级",  path="/module/com/combobox/index.js")
    div.searchbutton
      button(name="btnSearch", title="搜索规则", value="搜索", path="/module/com/form/button.js")
    div.searchbutton
      button(name="btnAddRule", title="添加规则", value="添加规则", path="/module/com/form/button.js")
    div.clearfloat
  div
    div.rulemanagelist-panel
      div.rulemanagelist-tab
        span(class="rulemanagelist-tab-active", value=0) 已上线
        span(class="rulemanagelist-tab-deactive", value=1) 已删除
    div
      label(id="rulecount") 
    div
      list(name="rulemanagelist", highlightrow="false", module="/page/rulemanage/", action="./mockdata", rowtpls="rulemanagelist",  page="true", pagesize="5", ispagestartbyindex="true", path="/module/com/list/list.js")