- var rank = '提醒', variable = '关闭', detail = self.detail
if self.rank == 2
  rank = '禁止'
if self.replaceParamStatus == 0
  variable = '开启'
if detail.length > 50
  detail = detail.substr(0,45) + '...'
div
  div.rule-list
    div.rulelist-field  #{self.id} #{self.name}
    div.rulelist-field
      span 创建人： #{self.author}
      span 限制等级: #{rank}
      label(value="authorization") 授权范围
    div.rulelist-field
      div.rule-time
        span 变量强制替换: #{variable}
        span 更新时间： #{self.updatedAt}
        span 创建时间： #{self.createdAt}
    div.rulelist-field
      div
        div.rule-desc #{detail}
        div.rule-detail #{self.detail}

