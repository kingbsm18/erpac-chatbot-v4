- type = 'sysytem'
if self.type == '2'
  type = 'script'
else if self.type == '3'
  type = 'halfOpen'
div.sourcelist
  div.sourcelist-fie
    div.sourcelist-value #{self.name}
    div.sourcelist-value 作者： #{self.author}
    div.sourcelist-value 类型： #{type}
    div.sourcelist-name 更新时间: #{self.updatedAt}
  div.sourcelist-fie
    div.sourcelist-desc #{self.detail}
    div.sourcelist-name  创建时间: #{self.createdAt}