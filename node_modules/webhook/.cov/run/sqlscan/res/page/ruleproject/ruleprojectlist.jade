div
  div.ruleproject-list
    div.ruleprojectlist-field
      span 应用ID： #{self.id} 
      span 负责人（工号）： #{self.owner}
    div.ruleprojectlist-field
      span 应用名称： #{self.name} 
      span 应用标识： #{self.odpsProjectName}
      if self.isOwner
        if self.applicationProperty.property.sqlscan_open == '1'
          button(class="btnDisableRule") 停用规则
          button(class="btnEnableRule", disabled="disabled") 启用规则
        else
          button(class="btnDisableRule", disabled="disabled") 停用规则
          button(class="btnEnableRule") 启用规则
      else
        button(class="btnDisableRule", disabled="disabled") 停用规则
        button(class="btnEnableRule", disabled="disabled") 启用规则
    div.ruleprojectlist-field
      div.rule-time
        span 更新时间： #{self.gmtModify}
        span 创建时间： #{self.gmtCreate}
