div
  div.authorizeitem
    div.authorizeitem-value
      combobox(name="appId", value="#{self.proValue ? self.proValue : ''}", valuekey="odpsProjectName", textkey="name", allowblank="false", placeholder="请选择应用名", path="/module/com/combobox/index.js")
    div.authorizeitem-and &rArr;
    div.authorizeitem-value
      combobox(name="owner", value="#{self.usersValue ? self.usersValue : ''}", valuekey="odpsDisplayName", textkey="nickName", allowblank="false", placeholder="请选择用户", multiple="true", showempty="true", showemptyvalue="*", path="/module/com/combobox/index.js")
    div.authorizeitem-btn
      button(name="btnRemove", title="删除授权", value="X", path="/module/com/form/button.js")