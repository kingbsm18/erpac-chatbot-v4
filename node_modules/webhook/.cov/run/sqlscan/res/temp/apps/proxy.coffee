request        = require 'request'
ep             = require 'event-pipe'
os             = require 'options-stream'
yaml           = require 'yamljs'
util           = require 'util'
ul             = require '../util'

getDefaultParam = (req) ->
  userInfo = 
    'WorkId' : 'WORKFLOW'
  if req.session and req.session.user
    userInfo = req.session.user
  defaultParam =
    'loginId' : userInfo.WorkId
    'requestId' : ul.randRequestId()
  defaultParam

class Proxy
  constructor : (option) ->
    @log = option.log

    @options = option.opt
    @authInfo = @options.authInfo
    @aliyun = @options.aliyun

    if @options.request then @_request = @options.request else @_request = request

  request : (opt, req, cb) ->
    url = opt.url.split '/'
    param = opt.param

    if util.isArray(param) or typeof(param) is 'object'
      param = JSON.stringify(param)

    defaultParam = getDefaultParam req
    
    process.honeycomb.rest.getUrl '', url[0], url[1], url[2], [JSON.stringify(defaultParam), param], {}, (err, uri) =>
      if err
        cb err
      else
        @log.info 'param' : uri
        requestOpt = 
          method : 'get'
          url : uri
        if uri.length > 2000
          uris = uri.split '?'
          requestOpt.method = 'post'
          requestOpt.url = uris.shift()
          postData = uris.join('?')
          requestOpt.body = postData
          requestOpt.headers =
            'Content-Type': 'application/x-www-form-urlencoded',
            'Content-Length': Buffer.byteLength(postData, 'utf-8')
        @_request requestOpt, (err, resp, body) =>
          cb err, resp, body

  getUserOdpsInfos : (param, req, cb) ->
    opt = 
      url : 'user/UserAPI/getUserDecodeOdpsInfo'
      param : param.userId

    @request opt, req, (err, resp, body) =>
      if err
        cb err, resp, body
      else
        result = JSON.parse body
        if (result.returnCode + '') isnt '0'
          cb result, resp, body
        else
          cb null, resp, result

  getUserInfos : (param, req, cb) ->
    requestParam = [param.userId]
    opt = 
      url : 'user/UserAPI/getUserById'
      param : requestParam.join ','

    @request opt, req, (err, resp, body) =>
      if err
        cb err, resp, body
      else
        result = JSON.parse body
        if (result.returnCode + '') isnt '0'
          cb result, resp, body
        else
          cb null, resp, result

  saveUserAuth : (param, req, cb) ->
    self = @

    pipe = ep()
    pipe.add () ->
      self.aliyun.randUser param.userId, (err, userInfo) =>
        if err
          cb err
          @__stop()
          return
        @userInfo = userInfo
        @()
    pipe.add () ->
      requestParam =
        id : param.userId
        odpsDisplayName : @userInfo.odpsDisplayName
        odpsAccessId : @userInfo.odpsAccessId
        odpsAccessKey : @userInfo.odpsAccessKey

      opt = 
        url : 'user/UserAPI/saveUser'
        param : JSON.stringify requestParam

      self.request opt, req, (err, resp, body) =>
        if err
          cb err
        else
          result = JSON.parse body
          if (result.returnCode + '') isnt '0'
            cb result
          else
            cb null, @userInfo
        @()

    pipe.run()

  getUser : (param, req, cb) ->
    self = @

    pipe = ep()
    pipe.add [
      () ->
        self.getUserOdpsInfos param, req, (err, resp, body) =>
          if err
            cb err, body
            @__stop()
          else
            result = body.returnValue
            if not result or result.length is 0
              error = new Error '用户没有accessid和accesskey'
              cb error, body
              @__stop()
            else if !result.odpsAccessId and !result.odpsDisplayName and !result.odpsAccessKey
              self.saveUserAuth param, req, (err, auth) =>
                if err
                  cb err
                  @__stop()
                else
                  @odpsUser = auth
                  @()
            else
              @odpsUser = result
              @()
      , () ->
        self.getUserInfos param, req, (err, resp, body) =>
          if err
            cb err, body
            @__stop()
          else
            result = body.returnValue
            if result.length is 0
              error = new Error '没有该用户信息'
              cb error, body
              @__stop()
            else
              @user = result[0]
            @()
      ]

    pipe.add () ->
      @user.odpsAccessId = @odpsUser.odpsAccessId
      @user.odpsDisplayName = @odpsUser.odpsDisplayName
      @user.odpsAccessKey = @odpsUser.odpsAccessKey

      cb null, @user
      @()

    pipe.run()

  inUserList : (userName, list) ->
    for user in list
      return true if ('ALIYUN$' + userName).toLowerCase() is user.DisplayName.toLowerCase()
    return false

  checkCreateAuth : (req, response, param, proxy) ->
    if @hasCreateAuth param.userId
      result =
        returnCode : '0'
        returnValue : true
    else
      result =
        returnCode : '0'
        returnValue : false
    proxy.done JSON.stringify(result), response

  hasCreateAuth : (userId) ->
    whiteListConf = yaml.load @options.whiteListFile
    if userId in whiteListConf.users or "*" in whiteListConf.users
      true
    else
      false

  getCluster : (req, response, param, proxy) ->
    cluster = []
    @odpsProject.getClusterConfig {
        'authInfo' : @authInfo
      }, (err, resp, body)=>
        return proxy.error err, response if err
        for key of body
          cluster.push key
        result =
          returnCode : '0'
          returnValue : cluster
        proxy.done JSON.stringify(result), response

  getQuota : (req, response, param, proxy) ->
    cluster = param.cluster
    quotas = []

    @odpsProject.getQuotaConfig {
        'authInfo' : @authInfo
        'cluster' : cluster
      }, (err, resp, body)=>
        return proxy.error err, response if err
        for quota, index in body
          if index is 0
            continue
          quotas.push
            'id' : quota[0]
            'quotagroup' : quota[1]
            'cpu' : quota[2]
            'memory' : quota[3]
            'availableQuota' : quota[4]

        result =
          returnCode : '0'
          returnValue : quotas
        proxy.done JSON.stringify(result), response

  getBu : (req, response, param, proxy) ->

    bu = yaml.load @options.bu
    result =
      returnCode : '0'
      returnValue : bu
    proxy.done JSON.stringify(result), response

  getUserOdpsInfo : (req, response, param, proxy) ->

    @getUserOdpsInfos userId : req.session.user.id, req, (err, resp, body) =>
      if err
        proxy.error err, response
        return;
      proxy.done JSON.stringify(body), response

  error : (req, response, param, proxy) ->
    response.catError param.code, param.error

  checkConsoleAuth : (req, response, param, proxy) ->
    @authConsole req, param, (err, result) =>
      return proxy.error err, response if err
      proxy.done JSON.stringify({
          returnCode : '0'
          returnValue : result
        }), response

  authConsole : (req, param, cb) ->
    userId = req.session.user.id
    appId = param.appId
    resultBody =
      returnCode : '0'
      returnValue : true
    # pe有权限
    return cb null, true if @isPe userId
    return cb null, false unless appId
    opt = 
      url : 'application/ApplicationAPI/getAppMemberInfo'
      param :
        appId : appId
        userId : userId
    @request opt, req, (err, resp, body) =>
      return cb err if err
      result = JSON.parse body
      # owner和pm有权限
      if result.returnCode is '0' and result.returnValue.length >= 1
        for role in result.returnValue[0].roles
          return cb null, true if role.code is 'OWNER' or role.code is 'PM'
        # 在白名单里面的人有权限
        return cb null, true if @hasConsoleAuth userId
      # 其他人没权限
      cb null, false


  isPe : (userId) ->
    whiteListConf = yaml.load @options.whiteListFile
    if userId in whiteListConf.users
      true
    else
      false

  hasConsoleAuth : (userId) ->
    whiteListConf = yaml.load @options.whiteListFile
    if userId in whiteListConf.consoleUsers
      true
    else
      false

  getMyApps : (req, response, param, proxy) ->
    userId = req.session.user.id

    resultBody =
      returnCode : '0'
      returnValue : false

    if @isPe userId
      opt = 
        url : 'application/ApplicationAPI/getApplications'
        param : param
    else
      filter = true
      opt = 
        url : 'application/ApplicationAPI/getApplicationByUser'
        param : userId

    @request opt, req, (err, resp, body) =>
      if err
        proxy.error err, response
      else
        if filter
          data = JSON.parse body
          if data.returnCode is '0'
            @filterApp data.returnValue, userId, req, (result) =>
              proxy.done result, response
          else
            proxy.done body, response
          return
        proxy.done body, response

  filterApp : (record, userId, req, cb) ->
    body =
      returnCode : '0'
    pipe = ep()
    apps = []
    pipeFn = []
    self = @
    checkAppRole = (app, userId) ->
      ->
        opt = 
          url : 'application/ApplicationAPI/getAppMemberInfo'
          param :
            appId : app.id
            userId : userId
        self.request opt, req, (err, resp, body) =>
          return @() if err
          result = JSON.parse body
          if result.returnCode is '0' and result.returnValue.length >= 1
            for role in result.returnValue[0].roles
              if role.code is 'OWNER' or role.code is 'PM'
                apps.push app
                @()
                return
            apps.push app if self.hasConsoleAuth userId
          @()

    for app in record
      if app.type is 10
        pipeFn.push checkAppRole app, userId

    pipe.add pipeFn

    pipe.add ->
      body.returnValue = apps
      cb JSON.stringify body

    pipe.run()

exports = module.exports = Proxy