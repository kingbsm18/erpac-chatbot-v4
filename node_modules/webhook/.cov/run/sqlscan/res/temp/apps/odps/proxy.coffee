request        = require 'request'
ep             = require 'event-pipe'
crypto         = require 'crypto'
os             = require 'options-stream'
justlog        = require 'justlog'
xml2js         = require 'xml2js'

parser = new xml2js.Parser explicitArray: false

class Proxy

  constructor: (option) ->
    @options = os {
      request : null
    }, option

    @prefix = @options.prefix

    @options.request = request unless @options.request

    if @options.logs_dir
      @log = justlog
        file :
          level : justlog.ERROR | justlog.INFO
          path : "[#{@options.logs_dir}/odps-]YYYY-MM-DD[.log]"
          pattern : "{fulltime} [{levelTrim}] {msg} {param} {error}"
        stdio : false
    else
      @log = error:(->), info:(->)

  req : (opt, cb) ->
    AuthInfo = opt.AuthInfo
    mt = opt.method
    url = opt.url
    head = os {}, opt.head || {}
    body = opt.body
    prefix = @prefix
    head["Cache-Control"] = "no-cache"
    head["If-Modified-Since"] = 0
    head["Expires"] = 0

    return false if not AuthInfo
    if AuthInfo.id and AuthInfo.key
      sortURL = @getSortURL url

      hmac = crypto.createHash 'md5'
      head['content-md5'] = hmac.update(body).digest 'hex' if body isnt ""

      hds = []
      for i, value of head
        # by firefox
        hds[i.toLowerCase()] = value
        if not hds['content-type'] or hds['content-type'] is ''
          hds['content-type']='text/plain; charset=UTF-8'
        delete hds[i] if not hds[i] or hds[i] is ''
      head = hds

      auths = @getAuthString AuthInfo.key, mt, head, sortURL
      # head['Authorization']="ODPS "+AuthInfo.id+":"+auths;

      head['Authorization'] = "account_provider:aliyun,signature_method:hmac-sha1,access_id:#{AuthInfo.id},signature:#{auths}"

    else if AuthInfo.accesstoken
      head['Authorization'] = "account_provider:domain,protocol:ark,access_token:#{AuthInfo.accesstoken}"
       
    param = 
      method : mt
      url : prefix + url
      headers : head
      body : body


    @log.info param : JSON.stringify param
    @options.request param, (error, response, body) =>
      @log.error 'error' : error.toString() if error
      if opt.autoParse isnt false and body
        parser.parseString body, (err, result) =>
          cb err, response, result, response.statusCode
        return
      cb error, response, body, response.statusCode

    @

  getSortURL : (url) ->
    if url.indexOf("?") > 0
      uri = url.substring 0, url.indexOf "?"
      querystr = url.substring url.indexOf("?") + 1

      querystr = querystr.replace(/(^\s*)|(\s*$)/g, '').replace(/(^\&*)|(\&*$)/g, '')
      return uri if querystr is ""

      arr = querystr.split /\s*\&\s*/g
      arr.sort (a,b) =>
        if a > b then return 1 else return -1
      uri + "?" + arr.join("&")
    else
      url

  getAuthString : (accessKey, method, hds, uri) ->
    cd =  @getGMTString()
    hds['x-odps-date'] = hds['x-odps-date'] ||  cd

    headers = {}
    for i, value of hds
      headers[i.toLowerCase()] = value

    t = []
    t.push method.toUpperCase()
    t.push headers['content-md5'] || ""
    t.push headers['content-type'] || ""
    t.push cd
 
    xt = []
    for i, value of headers
      if i.indexOf('x-odps-') is 0
        xt.push "#{i}:#{value}"

    xt.sort()
    t.push xt.join "\n"
    t.push uri
    hmac = crypto.createHmac 'sha1', accessKey
    auth = hmac.update(t.join("\n")).digest('base64')

    auth

  getGMTString : (t) ->
    if t
      d = new Date(t).toGMTString().replace /UTC/,'GMT'
    else
      d = new Date().toGMTString().replace /UTC/,'GMT'
    arr= d.split /, (\d[^\d])/
    if arr.length is 3
      "#{arr[0]}, 0#{arr[1]}#{arr[2]}"
    else
      d

exports = module.exports = Proxy
