os           = require 'options-stream'
Proxy        = require './proxy'

class Project
  constructor: (option) ->

    @Proxy = new Proxy option

    @head = 
      'content-type' : 'application/xml'

  create : (data, cb) ->
    url = '/projects/admin_task_project/instances'

    authInfo = 
      id : data.authInfo.accessId
      key : data.authInfo.accessKey

    odpsInfo = data.odpsInfo

    body = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>
      <Instance><Job><Comment/>
      <Priority>1</Priority><Tasks><Admin><Name>#{data.name}</Name><Comment/><Config>
      <Property>
      <Name>project</Name>
      <Value>#{data.name}</Value>
      </Property>
      <Property>
      <Name>owner</Name>
      <Value>aliyun$#{data.email}</Value>
      </Property>
      <Property>
      <Name>defaultcluster</Name>
      <Value>"
    body += odpsInfo.defaultCluster.cluster
    body += "</Value>
      </Property>
      <Property>
      <Name>clusters</Name>
      <Value><![CDATA["
        # {\"ATIFB\":{\"quota\":166,\"location\":\"\"}}
    clusters = {}
    for cluster in odpsInfo.clusters
      clusters[cluster.cluster] =
        "quota" : cluster.quota/1
        "location" : ""
    body += JSON.stringify clusters
    body += "]]></Value>
      </Property>
      <Property>
      <Name>properties</Name>
      <Value>"
    properties = 
      "COMMON" : {}
      "ADMIN_SETTING" :
        "buid" : odpsInfo.bu
    if odpsInfo.storageQuota
      properties.COMMON.PROJECT_QUOTA_FILE_LENGTH = odpsInfo.storageQuota
    if odpsInfo.fileNumber
      properties.COMMON.PROJECT_QUOTA_FILE_NUMBER = odpsInfo.fileNumber
        
    body += JSON.stringify properties
    body += "</Value>
      </Property>
      </Config>
      <Command>create_project</Command></Admin></Tasks><DAG><Comment/><RunMode>Sequence</RunMode></DAG></Job></Instance>"

    opt =
      AuthInfo : authInfo
      method : 'POST'
      url : url
      head : @head
      body : body

    # console.log 'create project'
    # process.nextTick ->
    #   cb null, null, Result : 'OK'
    @Proxy.req opt, (error, response, body) =>
      if error  
        cb error, response, body
      else if body.Error
        err = new Error body.Error.Message
        err.code = body.Error.Code
        cb err, response, body
      else if body.Instance.Tasks.Task.Result is 'OK'
        @setPriority data, cb
      else
        err = new Error body.Instance.Tasks.Task.Result
        err.code = 'CREATEPROJECTERROR'
        cb err, response, body

  get : (data, cb) ->
    url = "/projects/admin_task_project/instances"
    authInfo = 
      id : data.authInfo.accessId
      key : data.authInfo.accessKey

    body = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>
      <Instance><Job><Comment/>
      <Priority>1</Priority><Tasks><Admin><Name>#{data.name}</Name><Comment/><Config>
      <Property>
      <Name>project</Name>
      <Value>#{data.name}</Value>
      </Property>
      </Config>
      <Command>get_project_basic_meta</Command></Admin></Tasks><DAG><Comment/><RunMode>Sequence</RunMode></DAG></Job></Instance>"


    opt =
      AuthInfo : authInfo
      method : 'POST'
      url : url
      head : @head
      body : body

    @Proxy.req opt, (error, response, body) =>
      if error
        cb error, response, body
      else if body.Error
        err = new Error body.Error.Message
        err.code = body.Error.Code
        cb err, response, body
      else
        try
          cb null, response, JSON.parse(body.Instance.Tasks.Task.Result).getProjectBasicMeta
        catch e
          cb body.Instance.Tasks.Task.Result, response, body

  set : (data, cb) ->
    url = '/projects/admin_task_project/instances'

    authInfo = 
      id : data.authInfo.accessId
      key : data.authInfo.accessKey

    odpsInfo = data.app

    body = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>
      <Instance><Job><Comment/>
      <Priority>1</Priority><Tasks><Admin><Name>#{odpsInfo.name}</Name><Comment/><Config>
      <Property>
      <Name>project</Name>
      <Value>#{odpsInfo.name}</Value>
      </Property>
      <Property>
      <Name>owner</Name>
      <Value>aliyun$#{odpsInfo.owner}</Value>
      </Property>
      <Property>
      <Name>defaultcluster</Name>
      <Value>"
    body += odpsInfo.defaultCluster
    body += "</Value>
      </Property>
      <Property>
      <Name>clusters</Name>
      <Value><![CDATA["
    body += JSON.stringify odpsInfo.clusters
    body += "]]></Value>
      </Property>
      <Property>
      <Name>ACCESSMODE</Name>
      <Value>#{odpsInfo.accessMode}</Value>
      </Property>
      </Config>
      <Command>set_project_basic_meta</Command></Admin></Tasks><DAG><Comment/><RunMode>Sequence</RunMode></DAG></Job></Instance>"

    opt =
      AuthInfo : authInfo
      method : 'POST'
      url : url
      head : @head
      body : body

    @Proxy.req opt, (error, response, body) =>
      if error  
        cb error, response, body
      else if body.Error
        err = new Error body.Error.Message
        err.code = body.Error.Code
        cb err, response, body
      else if body.Instance.Tasks.Task.Result is 'OK'
        cb null, response, body
      else
        err = new Error body.Instance.Tasks.Task.Result
        err.code = 'UPDATEPROJECTERROR'
        cb err, response, body

  createRole : (data, cb) ->
    url = "/projects/#{data.name}/authorization"
    authInfo = 
      id : data.authInfo.accessId
      key : data.authInfo.accessKey

    body = '<?xml version="1.0" encoding="UTF-8"?>
      <Authorization>
        <Query>
          <![CDATA[
          CREATE ROLE ' + data.role + ';
          ]]>
        </Query>
      </Authorization>'

    opt =
      AuthInfo : authInfo
      method : 'POST'
      url : url
      head : @head
      body : body

    # console.log 'create role'
    # process.nextTick ->
    #   cb null, null, Result : 'OK'

    @Proxy.req opt, (error, response, body) =>
      if error
        cb error, response, body
      else if body.Error
        err = new Error body.Error.Message
        err.code = body.Error.Code
        cb err, response, body
      else
        cb null, response, body

  registEvents : (data, cb) ->
    url = "/projects/#{data.name}/registration/events"
    authInfo = 
      id : data.authInfo.accessId
      key : data.authInfo.accessKey

    body = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>
            <Event>
              <Name>#{data.eventName}</Name>
              <Comment>#{data.eventComment}</Comment>
              <Type>#{data.eventType}</Type>
              <Config>"
    for property in data.propertis
      body += "<Property>
                  <Name>#{property.name}</Name>
                  <Value>#{property.value}</Value>
                </Property>
              "
    body +=  "</Config>
              <URI>#{data.callBackUrl}</URI>
            </Event>"

    opt =
      AuthInfo : authInfo
      method : 'POST'
      url : url
      head : @head
      body : body

    @Proxy.req opt, (error, response, body) =>
      if error
        cb error, response, body
      else if body and body.Error
        err = new Error body.Error.Message
        err.code = body.Error.Code
        cb err, response, body
      else
        cb null, response, body

