      AuthInfo : authInfo
      method : 'POST'
      url : url
      head : @head
      body : body

    @Proxy.req opt, (error, response, body) =>
      if error
        cb error, response, body
      else if body.Error
        err = new Error body.Error.Message
        err.code = body.Error.Code
        cb err, response, body
      else
        try
          cb null, response, JSON.parse body.Instance.Tasks.Task.Result
        catch e
          cb body.Instance.Tasks.Task.Result, response, body

  getQuotaConfig : (data, cb) ->
    url = "/projects/admin_task_project/instances"
    authInfo = 
      id : data.authInfo.accessId
      key : data.authInfo.accessKey

    body = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>
      <Instance><Job><Comment/>
      <Priority>1</Priority><Tasks><Admin><Name>task_1</Name><Comment/><Config>
      <Property>
      <Name>cluster</Name>
      <Value>#{data.cluster}</Value>
      </Property>
      </Config>
      <Command>list_cluster_quota</Command></Admin></Tasks><DAG><Comment/><RunMode>Sequence</RunMode></DAG></Job></Instance>"


    opt =
      AuthInfo : authInfo
      method : 'POST'
      url : url
      head : @head
      body : body
    @Proxy.req opt, (error, response, body) =>
      if error
        cb error, response, body
      else if body.Error
        err = new Error body.Error.Message
        err.code = body.Error.Code
        cb err, response, body
      else
        try
          cb null, response, JSON.parse body.Instance.Tasks.Task.Result
        catch e
          cb body.Instance.Tasks.Task.Result, response, body

  setPriority : (data, cb) ->
    url = '/projects/admin_task_project/instances'

    authInfo = 
      id : data.authInfo.accessId
      key : data.authInfo.accessKey

    odpsInfo = data.odpsInfo

    body = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>
      <Instance><Job><Comment/>
      <Priority>1</Priority><Tasks><Admin><Name>#{data.name}</Name><Comment/><Config>
      <Property>
      <Name>project</Name>
      <Value>#{data.name}</Value>
      </Property>
      <Property>
      <Name>properties</Name>
      <Value>"

    properties = 
      "COMMON" :
        "AUTO_AJUST_PRIORITY" : "false"
        "PROJECT_PRIORITY" : "#{odpsInfo.priority}"
      "ADMIN_SETTING" :
        "buid" : odpsInfo.bu
    if odpsInfo.storageQuota
      properties.COMMON.PROJECT_QUOTA_FILE_LENGTH = odpsInfo.storageQuota
    if odpsInfo.fileNumber
      properties.COMMON.PROJECT_QUOTA_FILE_NUMBER = odpsInfo.fileNumber
      
    body += JSON.stringify properties
    body += "</Value>
      </Property>
      </Config>
      <Command>SET_PROJECT_EXT_META</Command></Admin></Tasks><DAG><Comment/><RunMode>Sequence</RunMode></DAG></Job></Instance>"

    opt =
      AuthInfo : authInfo
      method : 'POST'
      url : url
      head : @head
      body : body

    @Proxy.req opt, (error, response, body) =>
      if error  
        cb error, response, body
      else if body.Error
        err = new Error body.Error.Message
        err.code = body.Error.Code
        cb err, response, body
      else if body.Instance.Tasks.Task.Result is 'OK'
        cb null, response, body
      else
        cb body.Instance.Tasks.Task.Result, response, body

exports = module.exports = (options) ->
  new Project options
