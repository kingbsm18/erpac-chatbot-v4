    body = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>
      <Instance><Job><Comment/>
      <Priority>1</Priority><Tasks><Admin><Name>task_1</Name><Comment/><Config>
      <Property>
      <Name>CLUSTER_CONFIG</Name>
      <Value></Value>
      </Property>
      </Config>
      <Command>get_odps_service_config</Command></Admin></Tasks><DAG><Comment/><RunMode>Sequence</RunMode></DAG></Job></Instance>"


