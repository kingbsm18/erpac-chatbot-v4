meta(charset="utf-8")
style
  *{
    font-size: 12px;
    margin: 0px;
    padding: 0px;
  }
  ol, ul{
    list-style: none;
  }
  div:focus{
    outline: none;
  }
  html, body{
    height: 100%;
  }
  body{
    background-position: 50% 100px;
    background-repeat: no-repeat;
  }  
  .container{
    min-height: 100%;
    height: 100%;
    height: auto;
    position: relative;
  }    
  .container .header{
    width: 100%;
  }
  .container .body{
    display: -webkit-box;
    flex-flow: row;
    width: 980px;
    margin: 0 auto;
    padding-bottom: 295px;
  }
  .container .footer{
    background: #fafafa;
    left: 0px;
    right: 0px;
    bottom: 0px;
    position: absolute;
    height: 275px;
    clear: both;
    color: #999;
    font-size: 12px;
    overflow: hidden;
  }
  .container .footer .wrapper{
    height: 275px;
    width: 845px;
    margin: 0 auto;
  }
  .container .footer .wrapper a{
    text-decoration: none;
    color: #666;
  }
  .container .footer .wrapper .relcontainer{
    display: -webkit-box;
    display: -maz-box;
    position: relative;
    margin-top: 40px;
    margin-bottom: 60px;
  }
  .container .footer .wrapper .relcontainer .title{
    font-size: 14px;
    font-weight: bold;
    color: #4e4e4e;
    margin-bottom: 15px;
  }
  .container .footer .wrapper .relcontainer .relation{
    width:220px;
    margin-left: 0px
  }
  .container .footer .wrapper .relcontainer .contactus{
    width:220px;
    margin-left: 100px
  }
  .container .footer .wrapper .relcontainer .abort{
    width:120px;
    margin-left: 180px
  }
  .container .footer .wrapper .relcontainer ul li {
    color :#999;
    padding-top: 5px;
    padding-bottom: 5px;
  }
  .container .footer .wrapper .relcontainer ul li a{
    color: #999;
  }
  .container .footer .wrapper .relation ul li .end{
    border: none;
  }
  .container .footer .wrapper .relation .powered{
    position: absolute;
    right: 0px;
    top: 7.5px;
  }
  .container .footer .wrapper .copyright{
    text-align: center;
    margin-top: 22px;
  }
  .container .footer .wrapper .copyright a{
    color: #999;
  }

