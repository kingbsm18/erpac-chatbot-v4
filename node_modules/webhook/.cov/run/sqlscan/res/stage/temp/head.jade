meta(charset="utf-8")
style
  *{
    font-size: 12px;
    margin: 0px;
    padding: 0px;
  }
  ol, ul{
    list-style: none;
  }
  div:focus{
    outline: none;
  }
  html, body{
    height: 100%;
  }
  body{
    background-position: 50% 100px;
    background-repeat: no-repeat;
  }  
  .container{
    min-height: 100%;
    height: 100%;
    height: auto;
    position: relative;
  }    
  .container .header{
    width: 100%;
  }
  .container .body{
    display: -webkit-box;
    flex-flow: row;
    width: 980px;
    margin: 0 auto;
    margin-top: 20px;
    padding-bottom: 123px;
  }
  .container .footer{
    background: #f5f5f5;
    left: 0px;
    right: 0px;
    bottom: 0px;
    position: absolute;
    height: 103px;
    clear: both;
    color: #666;
    font-size: 14px;
    border-top: 1px solid #d9d9d9;
  }
  .container .footer .wrapper{
    height: 102px;
    width: 980px;
    margin: 0 auto;
  }
  .container .footer .wrapper a{
    text-decoration: none;
    color: #666;
  }
  .container .footer .wrapper .relation{
    border-bottom: 1px solid #d9d9d9;
    height: 50px;
    position: relative;
  }
  .container .footer .wrapper .relation ul{
    position: absolute;
    left: 0px;
    top: 7.5px;
  }
  .container .footer .wrapper .relation ul li {
    float: left;
    padding: 0px 10px;
    border-right: 1px solid #d9d9d9;
  }
  .container .footer .wrapper .relation ul li .end{
    border: none;
  }
  .container .footer .wrapper .relation .powered{
    position: absolute;
    right: 0px;
    top: 7.5px;
  }
  .container .footer .wrapper .copyright{
    text-align: center;
    margin-top: 22px;
  }

