!!! 5
html
  head
    title sqlScan-在云端
    include ./temp/head
    script(src="/temp/browser.js")
    script
      var t = new Date();
      var __$qloader = {
        no_local_storage : #{no_local_storage},
        //- rev : '#{rev}',
        cb : function(err) {
          var path = '/page/remotepath.js';
          var viewport = '/page/index/viewport.js';
          this.loadJs([path, viewport],function(err, objs){
            objs[viewport]({
              //- host : '#{host}',
              //- controller : '#{controller}',
              //- atatech : '#{atatech}',
              app : 'sqlScan',
              configer : objs[path],
              prefix : '#{prefix}'
            });
          });
          this.loadCss('/page/', ['sqlscan'], 'common', function(){});
        }
      }
    script(src="/p/loader.js")
  body(class="page-common")
    include ./temp/body
